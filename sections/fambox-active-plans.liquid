<!-- ============================================
     FAMBOX ACTIVEプランセクション
     sections/fambox-active-plans.liquid
     WF: preview-active-plans.html
     ============================================ -->
{%- liquid
  assign sec_id = 'fambox-ap-' | append: section.id
-%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&display=swap');

  /* ============================================
     RESET
     ============================================ */
  #{{ sec_id }},
  #{{ sec_id }} *,
  #{{ sec_id }} *::before,
  #{{ sec_id }} *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ============================================
     SECTION BASE
     ============================================ */
  #{{ sec_id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    background: {{ section.settings.bg_color }} !important;
    overflow: visible;
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    -webkit-font-smoothing: antialiased;
  }

  /* ============================================
     FLOATING PARTICLES
     ============================================ */
  #{{ sec_id }} .ap__particles {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  #{{ sec_id }} .ap__particle {
    position: absolute;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    opacity: 0;
    animation: apFloat-{{ section.id }} linear infinite;
  }
  @keyframes apFloat-{{ section.id }} {
    0% { opacity: 0; transform: translateY(0) scale(0.3); }
    8% { opacity: 0.5; }
    85% { opacity: 0.4; }
    100% { opacity: 0; transform: translateY(-110vh) scale(1); }
  }

  /* ============================================
     INNER
     ============================================ */
  #{{ sec_id }} .ap__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 64px;
    position: relative;
    z-index: 2;
  }

  /* ============================================
     HEADER
     ============================================ */
  #{{ sec_id }} .ap__header {
    text-align: center;
    margin-bottom: 48px;
  }
  #{{ sec_id }} .ap__title {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-size: 40px !important;
    font-weight: 500 !important;
    color: #fff !important;
    line-height: 180% !important;
    margin-bottom: 16px !important;
    letter-spacing: normal !important;
    text-transform: none !important;
  }
  #{{ sec_id }} .ap__lead {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-size: 16px !important;
    font-weight: 400 !important;
    color: rgba(255,255,255,0.8) !important;
    line-height: 180% !important;
    max-width: 600px;
    margin: 0 auto !important;
  }

  /* ============================================
     TABS
     ============================================ */
  #{{ sec_id }} .ap__tabs {
    display: flex !important;
    justify-content: center;
    gap: 12px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  #{{ sec_id }} .ap__tab {
    display: flex !important;
    align-items: center;
    gap: 16px;
    padding: 4px 24px 4px 4px;
    border-radius: 42px;
    border: none !important;
    background: #1B1D1A;
    color: rgba(255,255,255,0.9) !important;
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-size: 15px !important;
    font-weight: 600 !important;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    text-decoration: none !important;
    height: 72px;
  }
  #{{ sec_id }} .ap__tab:hover {
    background: #2c2e2b;
    color: #fff !important;
  }
  #{{ sec_id }} .ap__tab--active {
    background: rgba(255,255,255,0.9) !important;
    color: #1B1D1A !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
  }
  #{{ sec_id }} .ap__tab--active:hover {
    background: rgba(255,255,255,0.9) !important;
    color: #1B1D1A !important;
  }
  #{{ sec_id }} .ap__tab-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }
  #{{ sec_id }} .ap__tab--active .ap__tab-avatar {
    background: #FB4C15;
  }
  #{{ sec_id }} .ap__tab-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block !important;
  }
  #{{ sec_id }} .ap__tab-label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: left;
  }
  #{{ sec_id }} .ap__tab-main {
    font-size: 16px !important;
    font-weight: 600 !important;
    line-height: 1.3 !important;
  }
  #{{ sec_id }} .ap__tab-sub {
    font-size: 12px !important;
    font-weight: 400 !important;
    opacity: 0.7;
    line-height: 1.3 !important;
  }
  #{{ sec_id }} .ap__tab--active .ap__tab-sub {
    opacity: 0.5;
  }

  /* ============================================
     CARDS AREA
     ============================================ */
  #{{ sec_id }} .ap__cards-area {
    position: relative;
    min-height: 500px;
    padding-bottom: 64px; /* シャドウ拡散距離分の余白 */
  }
  #{{ sec_id }} .ap__cards-group {
    display: none;
    justify-content: center;
    align-items: stretch;
    gap: 24px;
    animation: apFadeIn-{{ section.id }} 0.4s ease;
    flex-wrap: nowrap;
  }
  #{{ sec_id }} .ap__cards-group--active {
    display: flex !important;
  }
  @keyframes apFadeIn-{{ section.id }} {
    0% { opacity: 0; transform: translateY(12px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ============================================
     CARD
     ============================================ */
  #{{ sec_id }} .ap__card {
    width: calc((100% - 24px * 3) / 4);
    max-width: 304px;
    background: #fff !important;
    border-radius: 0;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  #{{ sec_id }} .ap__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.15);
  }

  /* カード画像 */
  #{{ sec_id }} .ap__card-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #ddd;
    overflow: hidden;
  }
  #{{ sec_id }} .ap__card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block !important;
  }
  #{{ sec_id }} .ap__card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex !important;
    align-items: center;
    justify-content: center;
    color: #999 !important;
    font-size: 14px !important;
    background: linear-gradient(135deg, #e8e8e8, #d0d0d0);
  }

  /* カードコンテンツ */
  #{{ sec_id }} .ap__card-content {
    padding: 24px;
  }
  #{{ sec_id }} .ap__card-plan {
    font-family: 'Poppins', sans-serif !important;
    font-size: 20px !important;
    font-weight: 500 !important;
    color: #1B1D1A !important;
    margin-bottom: 4px !important;
  }
  #{{ sec_id }} .ap__card-ja {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-size: 13px !important;
    font-weight: 500 !important;
    color: #92939C !important;
    margin-bottom: 16px !important;
  }
  #{{ sec_id }} .ap__card-target {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-size: 14px !important;
    font-weight: 500 !important;
    color: #1B1D1A !important;
    line-height: 170% !important;
    margin-bottom: 16px !important;
    min-height: 48px;
  }

  /* スペック */
  #{{ sec_id }} .ap__card-specs {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
  }
  #{{ sec_id }} .ap__card-spec {
    display: flex !important;
    justify-content: space-between;
    align-items: center;
    font-size: 13px !important;
    color: #545655 !important;
    padding-bottom: 8px;
    border-bottom: 1px solid #ECECEC;
  }
  #{{ sec_id }} .ap__card-spec:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  #{{ sec_id }} .ap__card-spec-label {
    font-weight: 400 !important;
  }
  #{{ sec_id }} .ap__card-spec-value {
    font-weight: 600 !important;
    color: #1B1D1A !important;
  }

  /* 価格 */
  #{{ sec_id }} .ap__card-price {
    margin-bottom: 20px;
    text-align: right !important;
  }
  #{{ sec_id }} .ap__card-price-main {
    font-family: 'Poppins', sans-serif !important;
    font-size: 28px !important;
    font-weight: 500 !important;
    color: #FB4C15 !important;
  }
  #{{ sec_id }} .ap__card-price-main span {
    font-size: 14px !important;
    font-weight: 400 !important;
    color: #92939C !important;
  }

  /* CTA */
  #{{ sec_id }} .ap__card-cta {
    position: relative;
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 48px;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.1);
    background: linear-gradient(to bottom, rgba(251,76,21,0.90), rgba(251,76,21,0.95)) !important;
    color: #fff !important;
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    text-decoration: none !important;
    letter-spacing: 0.08em;
    overflow: hidden;
    transition: filter 0.3s ease;
    box-shadow: 0 16px 16px -8px rgba(251,76,21,0.35);
  }
  #{{ sec_id }} .ap__card-cta:hover {
    filter: brightness(1.12);
    text-decoration: none !important;
    color: #fff !important;
  }
  #{{ sec_id }} .ap__card-cta-text {
    position: relative;
    z-index: 1;
  }
  #{{ sec_id }} .ap__card-cta-arrow {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    transition: transform 0.3s ease;
  }
  #{{ sec_id }} .ap__card-cta-arrow svg {
    display: block !important;
    width: 36px;
    height: 14px;
  }
  #{{ sec_id }} .ap__card-cta:hover .ap__card-cta-arrow {
    transform: translateY(-50%) translateX(4px);
  }

  /* ============================================
     SP (max-width: 767px)
     ============================================ */
  @media (max-width: 767px) {
    #{{ sec_id }} .ap__inner {
      padding: 80px 0 24px;
    }
    #{{ sec_id }} .ap__header {
      padding: 0 24px;
    }
    #{{ sec_id }} .ap__title {
      font-size: 28px !important;
    }
    #{{ sec_id }} .ap__lead {
      font-size: 14px !important;
    }
    /* タブ: 横スクロール（シャドウ見切れ防止: padding追加） */
    #{{ sec_id }} .ap__tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      justify-content: flex-start;
      padding: 12px 24px 16px;
      margin-top: -12px;
      scrollbar-width: none;
      -ms-overflow-style: none;
      gap: 8px;
    }
    #{{ sec_id }} .ap__tabs::-webkit-scrollbar { display: none; }
    #{{ sec_id }} .ap__tab {
      padding: 4px 16px 4px 4px;
      font-size: 13px !important;
      height: 56px;
    }
    #{{ sec_id }} .ap__tab-avatar {
      width: 48px;
      height: 48px;
    }
    #{{ sec_id }} .ap__tab-main {
      font-size: 13px !important;
    }
    #{{ sec_id }} .ap__tab-sub {
      font-size: 10px !important;
    }
    /* カードエリア: 下にシャドウ拡散距離分の余白（56px = blur40 + offset16） */
    #{{ sec_id }} .ap__cards-area {
      padding-bottom: 64px;
      min-height: auto;
    }
    /* カードグループ: 横スクロール + snap-center */
    #{{ sec_id }} .ap__cards-group {
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 16px;
      padding: 20px 0 56px;
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
    }
    #{{ sec_id }} .ap__cards-group::-webkit-scrollbar { display: none; }
    /* 左右のセンタリング用ダミー要素 */
    #{{ sec_id }} .ap__cards-group::before,
    #{{ sec_id }} .ap__cards-group::after {
      content: '';
      flex: 0 0 calc((100vw - 300px) / 2 - 8px);
    }
    #{{ sec_id }} .ap__card {
      flex: 0 0 300px;
      width: 300px;
      max-width: none;
      scroll-snap-align: center;
      scroll-snap-stop: always;
    }
    #{{ sec_id }} .ap__card-img {
      width: 100%;
      height: 0;
      padding-bottom: 100%;
      position: relative;
    }
    #{{ sec_id }} .ap__card-img img,
    #{{ sec_id }} .ap__card-img .ap__card-img-placeholder {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
  }

  /* ============================================
     REDUCED MOTION
     ============================================ */
  @media (prefers-reduced-motion: reduce) {
    #{{ sec_id }} .ap__particle {
      animation: none !important;
    }
  }
</style>

<section id="{{ sec_id }}">
  <!-- Floating Particles -->
  <div class="ap__particles" id="apParticles-{{ section.id }}">{%- comment -%}not empty{%- endcomment -%}</div>

  <div class="ap__inner">

    <!-- ========================================
         HEADER
         ======================================== -->
    <div class="ap__header">
      <h2 class="ap__title">{{ section.settings.title | newline_to_br }}</h2>
      <p class="ap__lead">{{ section.settings.lead | newline_to_br }}</p>
    </div>

    <!-- ========================================
         TABS
         ======================================== -->
    <div class="ap__tabs" id="apTabs-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'tab' -%}
          <button class="ap__tab{% if forloop.first %} ap__tab--active{% endif %}" data-tab="{{ block.settings.tab_key }}" {{ block.shopify_attributes }}>
            <div class="ap__tab-avatar">
              {%- if block.settings.tab_image != blank -%}
                {{ block.settings.tab_image | image_url: width: 96 | image_tag: alt: block.settings.tab_main }}
              {%- else -%}
                <div style="width:100%;height:100%;border-radius:50%;background:{% if forloop.first %}#FB4C15{% else %}rgba(255,255,255,0.3){% endif %};display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:700;">{%- comment -%}not empty{%- endcomment -%}</div>
              {%- endif -%}
            </div>
            <div class="ap__tab-label">
              <span class="ap__tab-main">{{ block.settings.tab_main }}</span>
              <span class="ap__tab-sub">{{ block.settings.tab_sub }}</span>
            </div>
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- ========================================
         CARDS AREA
         ======================================== -->
    <div class="ap__cards-area">
      {%- assign tab_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'tab' -%}
          <div class="ap__cards-group{% if tab_index == 0 %} ap__cards-group--active{% endif %}" data-group="{{ block.settings.tab_key }}">

            {%- comment -%} このタブに属するカードを出力 {%- endcomment -%}
            {%- for card_block in section.blocks -%}
              {%- if card_block.type == 'plan_card' -%}
                {%- assign card_tabs = card_block.settings.belongs_to_tabs | split: ',' -%}
                {%- for tab_name in card_tabs -%}
                  {%- assign trimmed = tab_name | strip -%}
                  {%- if trimmed == block.settings.tab_key -%}

                    <div class="ap__card" {{ card_block.shopify_attributes }}>
                      <div class="ap__card-img">
                        {%- if card_block.settings.card_image != blank -%}
                          {{ card_block.settings.card_image | image_url: width: 608 | image_tag: alt: card_block.settings.plan_name }}
                        {%- else -%}
                          <div class="ap__card-img-placeholder">320 × 320</div>
                        {%- endif -%}
                      </div>
                      <div class="ap__card-content">
                        <p class="ap__card-plan">{{ card_block.settings.plan_name }}</p>
                        <p class="ap__card-ja">{{ card_block.settings.plan_ja }}</p>
                        <p class="ap__card-target">{{ card_block.settings.target | newline_to_br }}</p>
                        <div class="ap__card-specs">
                          {%- if card_block.settings.spec1_label != blank -%}
                            <div class="ap__card-spec">
                              <span class="ap__card-spec-label">{{ card_block.settings.spec1_label }}</span>
                              <span class="ap__card-spec-value">{{ card_block.settings.spec1_value }}</span>
                            </div>
                          {%- endif -%}
                          {%- if card_block.settings.spec2_label != blank -%}
                            <div class="ap__card-spec">
                              <span class="ap__card-spec-label">{{ card_block.settings.spec2_label }}</span>
                              <span class="ap__card-spec-value">{{ card_block.settings.spec2_value }}</span>
                            </div>
                          {%- endif -%}
                          {%- if card_block.settings.spec3_label != blank -%}
                            <div class="ap__card-spec">
                              <span class="ap__card-spec-label">{{ card_block.settings.spec3_label }}</span>
                              <span class="ap__card-spec-value">{{ card_block.settings.spec3_value }}</span>
                            </div>
                          {%- endif -%}
                        </div>
                        <div class="ap__card-price">
                          <span class="ap__card-price-main">{{ card_block.settings.price }} <span>{{ card_block.settings.price_unit }}</span></span>
                        </div>
                        <a class="ap__card-cta" href="{{ card_block.settings.cta_url }}">
                          <span class="ap__card-cta-text">{{ card_block.settings.cta_text }}</span>
                          <span class="ap__card-cta-arrow">
                            {%- if card_block.settings.cta_arrow_svg != blank -%}
                              {{ card_block.settings.cta_arrow_svg }}
                            {%- else -%}
                              <svg width="36" height="14" viewBox="0 0 53 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <rect x="0" y="5" width="46" height="2" fill="white"/>
                                <path d="M46 0L53 6L46 12V0Z" fill="white"/>
                              </svg>
                            {%- endif -%}
                          </span>
                        </a>
                      </div>
                    </div>

                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            {%- endfor -%}

          </div>
          {%- assign tab_index = tab_index | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
(function() {
  var secEl = document.getElementById('{{ sec_id }}');
  if (!secEl) return;

  /* ===== TAB SWITCHING ===== */
  var tabs = secEl.querySelectorAll('.ap__tab');
  var groups = secEl.querySelectorAll('.ap__cards-group');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = this.dataset.tab;
      tabs.forEach(function(t) { t.classList.remove('ap__tab--active'); });
      this.classList.add('ap__tab--active');

      /* アバター色切替 */
      tabs.forEach(function(t) {
        var av = t.querySelector('.ap__tab-avatar > div');
        if (av) av.style.background = 'rgba(255,255,255,0.3)';
      });
      var activeAv = this.querySelector('.ap__tab-avatar > div');
      if (activeAv) activeAv.style.background = '#FB4C15';

      /* カードグループ切替 */
      groups.forEach(function(g) {
        g.classList.remove('ap__cards-group--active');
        g.style.animation = 'none';
      });
      var targetGroup = secEl.querySelector('[data-group="' + target + '"]');
      if (targetGroup) {
        void targetGroup.offsetWidth;
        targetGroup.style.animation = '';
        targetGroup.classList.add('ap__cards-group--active');

        /* SP: タブ切替後に最初のカードをセンターにスクロール */
        if (window.innerWidth <= 767) {
          var firstCard = targetGroup.querySelector('.ap__card');
          if (firstCard) {
            firstCard.scrollIntoView({ behavior: 'instant', inline: 'center', block: 'nearest' });
          }
        }
      }
    });
  });

  /* ===== SP: 初期表示時に最初のカード（ACTIVE 60）をセンターにスクロール ===== */
  if (window.innerWidth <= 767) {
    var activeGroup = secEl.querySelector('.ap__cards-group--active');
    if (activeGroup) {
      var firstCard = activeGroup.querySelector('.ap__card');
      if (firstCard) {
        firstCard.scrollIntoView({ behavior: 'instant', inline: 'center', block: 'nearest' });
      }
    }
  }

  /* ===== FLOATING PARTICLES ===== */
  var container = document.getElementById('apParticles-{{ section.id }}');
  if (!container) return;

  var count = Math.floor(Math.random() * 101) + 300;

  for (var i = 0; i < count; i++) {
    var p = document.createElement('div');
    p.className = 'ap__particle';

    var size = Math.random() * 7 + 1;
    p.style.width = size + 'px';
    p.style.height = size + 'px';
    p.style.left = Math.random() * 100 + '%';
    p.style.bottom = -(Math.random() * 5) + '%';

    var duration = Math.random() * 8 + 4;
    p.style.animationDuration = duration + 's';
    p.style.animationDelay = -(Math.random() * duration) + 's';

    var opacity = Math.random() * 0.27 + 0.08;
    p.style.background = 'rgba(255,255,255,' + opacity + ')';

    if (Math.random() < 0.15) {
      var bigSize = Math.random() * 5 + 8;
      p.style.width = bigSize + 'px';
      p.style.height = bigSize + 'px';
      p.style.background = 'rgba(255,255,255,' + (Math.random() * 0.15 + 0.05) + ')';
    }

    container.appendChild(p);
  }
})();
</script>

{% schema %}
{
  "name": "ACTIVEプラン",
  "tag": "section",
  "class": "fambox-active-plans-section",
  "settings": [
    {
      "type": "header",
      "content": "全体設定"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#FB4C15"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "セクションタイトル（改行可）",
