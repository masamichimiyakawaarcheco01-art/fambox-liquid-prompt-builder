{% comment %}
  Section: FAM アスリートの声
  File: sections/fam-voices.liquid
{% endcomment %}
<section class="fam-voices">
{% if section.settings.bg_noise != blank %}
<div class="fam-voices__bg-noise">
<img
src="{{ section.settings.bg_noise | image_url: width: 1440 }}"
alt=""
width="1440"
height="900"
aria-hidden="true"
>
</div>
{% endif %}
<div class="fam-voices__bg-gradient" aria-hidden="true"></div>
<!-- アスリート写真 PC用 -->
{% if section.settings.athlete_image_pc != blank %}
<div class="fam-voices__hero-pc">
<img
src="{{ section.settings.athlete_image_pc | image_url: width: 1000 }}"
alt="アスリート"
width="620"
height="800"
loading="lazy"
>
</div>
{% endif %}
<!-- アスリート写真 SP用 -->
{% if section.settings.athlete_image_sp != blank %}
<div class="fam-voices__hero-sp">
<img
src="{{ section.settings.athlete_image_sp | image_url: width: 500 }}"
alt="アスリート"
width="390"
height="518"
loading="lazy"
>
</div>
{% endif %}
<!-- タイトル・リード -->
<div class="fam-voices__content">
<div class="fam-voices__left">
<h2 class="fam-voices__title">{{ section.settings.title | newline_to_br }}</h2>
<p class="fam-voices__lead">{{ section.settings.lead | newline_to_br }}</p>
</div>
</div>
<!-- カード全幅 -->
<div class="fam-voices__cards-area">
<div class="fam-voices__row-wrap">
<div class="fam-voices__row" id="fam-voices-row1">
{% for block in section.blocks %}
{% if block.type == 'voice' and block.settings.row == 'top' %}
<div class="fam-voices__card" {{ block.shopify_attributes }}>
<div class="fam-voices__card-avatar">
{% if block.settings.avatar != blank %}
<img
src="{{ block.settings.avatar | image_url: width: 100, height: 100, crop: 'center' }}"
alt=""
width="76"
height="76"
loading="lazy"
>
{% else %}
<span class="fam-voices__card-avatar-default"></span>
{% endif %}
</div>
<div class="fam-voices__card-body">
<p class="fam-voices__card-text">{{ block.settings.text }}</p>
<p class="fam-voices__card-attr">{{ block.settings.attr }}</p>
</div>
</div>
{% endif %}
{% endfor %}
</div>
</div>
<div class="fam-voices__row-wrap">
<div class="fam-voices__row" id="fam-voices-row2">
{% for block in section.blocks %}
{% if block.type == 'voice' and block.settings.row == 'bottom' %}
<div class="fam-voices__card" {{ block.shopify_attributes }}>
<div class="fam-voices__card-avatar">
{% if block.settings.avatar != blank %}
<img
src="{{ block.settings.avatar | image_url: width: 100, height: 100, crop: 'center' }}"
alt=""
width="76"
height="76"
loading="lazy"
>
{% else %}
<span class="fam-voices__card-avatar-default"></span>
{% endif %}
</div>
<div class="fam-voices__card-body">
<p class="fam-voices__card-text">{{ block.settings.text }}</p>
<p class="fam-voices__card-attr">{{ block.settings.attr }}</p>
</div>
</div>
{% endif %}
{% endfor %}
</div>
</div>
</div>
<!-- FAMBOXロゴ -->
<div class="fam-voices__content fam-voices__content--bottom">
{% if section.settings.logo_image != blank %}
<div class="fam-voices__logo">
<img
src="{{ section.settings.logo_image | image_url: width: 200 }}"
alt="FAM BOX"
width="120"
height="40"
loading="lazy"
>
</div>
{% endif %}
</div>
</section>
<style>
/* ===== Section Base ===== */
.fam-voices {
position: relative;
z-index: 1; /* ヘッダー(z-index:3-4)より下に配置 */
background: #fafafa;
overflow: hidden;
padding: 120px 0;
}
/* ===== 背景ノイズ（下部配置・multiply） ===== */
.fam-voices__bg-noise {
position: absolute;
bottom: 0;
left: 0;
right: 0;
height: 60%;
z-index: 0;
pointer-events: none;
overflow: hidden;
}
.fam-voices__bg-noise img {
width: 100%;
height: 100%;
object-fit: cover;
object-position: bottom center;
display: block;
mix-blend-mode: multiply;
opacity: 0.15;
}
/* ===== 背景グラデーション ===== */
.fam-voices__bg-gradient {
position: absolute;
top: 0;
left: 0;
width: 100%;
height: 100%;
background: linear-gradient(180deg, rgba(250,250,250,0) 0%, #ffffff 100%);
opacity: 0.3;
pointer-events: none;
z-index: 0;
}
/* ===== アスリート写真 PC ===== */
.fam-voices__hero-pc {
display: none;
position: absolute;
bottom: 0;
top: auto;
right: max(0px, calc((100vw - 1440px) / 2));
width: 48%;
max-width: 660px;
height: 95%;
z-index: 1;
overflow: hidden;
}
.fam-voices__hero-pc img {
width: 100%;
height: 100%;
object-fit: contain;
object-position: right bottom;
display: block;
}
/* ===== アスリート写真 SP ===== */
.fam-voices__hero-sp {
display: block;
position: absolute;
top: 40px;
right: -40px;
width: 75%;
max-width: 300px;
z-index: 1;
overflow: hidden;
-webkit-mask-image: linear-gradient(180deg, #000 50%, transparent 88%);
mask-image: linear-gradient(180deg, #000 50%, transparent 88%);
}
.fam-voices__hero-sp img {
width: 100%;
height: auto;
display: block;
}
/* ===== コンテンツ制約（1440px・左64px） ===== */
.fam-voices__content {
position: relative;
z-index: 2;
max-width: 1440px;
margin: 0 auto;
padding: 0 64px;
}
.fam-voices__content--bottom {
margin-top: 48px;
}
/* ===== タイトル・リード ===== */
.fam-voices__left {
max-width: 520px;
}
.fam-voices__title {
font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", sans-serif;
font-size: 40px;
font-weight: 500;
line-height: 1.8;
color: #1B1D1A;
margin: 0 0 16px;
}
.fam-voices__lead {
font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", sans-serif;
font-size: 16px;
font-weight: 400;
line-height: 1.8;
color: #1B1D1A;
margin: 0;
}
/* ===== カードエリア（全幅） ===== */
.fam-voices__cards-area {
position: relative;
z-index: 2;
display: flex;
flex-direction: column;
gap: 16px;
margin-top: 48px;
width: 100%;
}
.fam-voices__row-wrap {
overflow: hidden;
width: 100%;
}
.fam-voices__row {
display: flex;
gap: 16px;
align-items: center;
will-change: transform;
}
#fam-voices-row2 {
padding-left: 120px;
}
/* ===== カード ===== */
.fam-voices__card {
flex: 0 0 auto;
display: flex;
align-items: center;
gap: 16px;
background: rgba(255, 255, 255, 0.9);
backdrop-filter: blur(16px);
-webkit-backdrop-filter: blur(16px);
border-radius: 42px;
padding: 4px 24px 4px 4px;
height: 84px;
box-sizing: border-box;
white-space: nowrap;
}
/* ===== アバター ===== */
.fam-voices__card-avatar {
width: 76px;
height: 76px;
min-width: 76px;
border-radius: 50%;
overflow: hidden;
background: transparent;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
}
.fam-voices__card-avatar img {
width: 100%;
height: 100%;
object-fit: cover;
display: block;
}
.fam-voices__card-avatar-default {
display: block;
width: 100%;
height: 100%;
background: #FB4C15;
border-radius: 50%;
}
/* ===== カードテキスト ===== */
.fam-voices__card-body {
display: flex;
flex-direction: column;
justify-content: center;
gap: 4px;
}
.fam-voices__card-text {
font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", sans-serif;
font-size: 18px;
font-weight: 500;
line-height: 1.3;
color: #FB4C15;
margin: 0;
}
.fam-voices__card-attr {
font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", sans-serif;
font-size: 12px;
font-weight: 400;
line-height: 1.3;
color: #FB4C15;
margin: 0;
}
/* ===== FAMBOXロゴ ===== */
.fam-voices__logo img {
display: block;
height: 28px;
width: auto;
}
/* ===== PC（768px以上） ===== */
@media (min-width: 768px) {
.fam-voices__hero-pc { display: block; }
.fam-voices__hero-sp { display: none; }
}
/* ===== SP（767px以下） ===== */
@media (max-width: 767px) {
.fam-voices {
padding: 80px 0;
  }
.fam-voices__content {
padding: 0 24px;
  }
.fam-voices__title {
font-size: 28px;
margin-bottom: 16px;
  }
.fam-voices__lead {
font-size: 14px;
text-shadow: 0px 4px 8px rgba(255,255,255,0.32);
  }
.fam-voices__cards-area {
margin-top: 32px;
gap: 12px;
  }
#fam-voices-row2 {
padding-left: 0;
  }
.fam-voices__card {
height: 56px;
padding: 0 20px 0 2px;
gap: 10px;
  }
.fam-voices__card-avatar {
width: 52px;
height: 52px;
min-width: 52px;
  }
.fam-voices__card-body {
gap: 4px;
  }
.fam-voices__card-text {
font-size: 13px;
line-height: 1.3;
  }
.fam-voices__card-attr {
font-size: 10px;
line-height: 1.3;
  }
.fam-voices__content--bottom {
margin-top: 32px;
  }
}
</style>
<script>
(function() {
function initRow(rowId, direction) {
var row = document.getElementById(rowId);
if (!row) return;
var originalCards = Array.from(row.children);
if (originalCards.length === 0) return;
for (var s = 0; s < 3; s++) {
originalCards.forEach(function(card) {
row.appendChild(card.cloneNode(true));
      });
    }
var gap = 16;
var totalWidth = 0;
requestAnimationFrame(function() {
originalCards.forEach(function(card) {
totalWidth += card.offsetWidth + gap;
      });
var viewportWidth = window.innerWidth;
while (totalWidth < viewportWidth * 2.5) {
originalCards.forEach(function(card) {
row.appendChild(card.cloneNode(true));
totalWidth += card.offsetWidth + gap;
        });
      }
var position = direction === 'rtl' ? -totalWidth : 0;
var speed = 0.5;
var rafId = null;
function animate() {
if (direction === 'rtl') {
position += speed;
if (position >= 0) position = -totalWidth;
        } else {
position -= speed;
if (Math.abs(position) >= totalWidth) position = 0;
        }
row.style.transform = 'translateX(' + position + 'px)';
rafId = requestAnimationFrame(animate);
      }
row.parentElement.addEventListener('mouseenter', function() {
cancelAnimationFrame(rafId);
      });
row.parentElement.addEventListener('mouseleave', function() {
rafId = requestAnimationFrame(animate);
      });
rafId = requestAnimationFrame(animate);
    });
  }
function init() {
initRow('fam-voices-row1', 'ltr');
initRow('fam-voices-row2', 'rtl');
  }
if (document.readyState === 'loading') {
document.addEventListener('DOMContentLoaded', init);
  } else {
init();
  }
})();
</script>
{% schema %}
{
"name": "FAM アスリートの声",
"settings": [
    {
"type": "textarea",
"id": "title",
"label": "タイトル（改行可）",
"default": "食事は自分で管理、\nでも本音は。\n現場のアスリートの声。"
    },
    {
"type": "textarea",
"id": "lead",
"label": "リード文（改行可）",
"default": "この声を、放っておけなかった。\nトップアスリートの栄養戦略を、\n冷凍宅配で誰もが手にできる環境に。"
    },
    {
"type": "image_picker",
"id": "athlete_image_pc",
"label": "アスリート写真（PC用）",
"info": "右側に表示。縦長推奨（700×900px以上）"
    },
    {
"type": "image_picker",
"id": "athlete_image_sp",
"label": "アスリート写真（SP用）",
"info": "右上に表示。縦長推奨（390×518px以上）"
    },
    {
"type": "image_picker",
"id": "logo_image",
"label": "FAM BOXロゴ"
    },
    {
"type": "image_picker",
"id": "bg_noise",
"label": "背景ノイズ画像",
"info": "グラデーション入りノイズ画像。下部に配置されます"
    }
  ],
"blocks": [
    {
"type": "voice",
"name": "アスリートの声",
"settings": [
        {
"type": "select",
"id": "row",
"label": "表示行",
"options": [
            { "value": "top", "label": "1行目（左→右）" },
            { "value": "bottom", "label": "2行目（右→左）" }
          ],
"default": "top"
        },
        {
"type": "image_picker",
"id": "avatar",
"label": "アバター画像（丸形）",
"info": "未設定の場合はオレンジ円で表示"
        },
        {
"type": "text",
"id": "text",
"label": "声のテキスト",
"default": "アスリートの声をここに入力"
        },
        {
"type": "text",
"id": "attr",
"label": "属性（年代・種目など）",
"default": "20代 プロ野球選手"
        }
      ]
    }
  ],
"presets": [
    {
"name": "FAM アスリートの声",
"blocks": [
        { "type": "voice", "settings": { "row": "top", "text": "パフォーマンスのためにバランスよく栄養を摂りたい", "attr": "20代 プロ野球選手" } },
        { "type": "voice", "settings": { "row": "top", "text": "遠征先では食事の選択肢はほぼない", "attr": "20代 プロ野球選手" } },
        { "type": "voice", "settings": { "row": "top", "text": "栄養管理するのは、個人では難しい", "attr": "20代 社会人硬式野球部選手" } },
        { "type": "voice", "settings": { "row": "top", "text": "増量したいが何をどれくらい食べるとよいか分からない", "attr": "20代 社会人硬式野球部選手" } },
        { "type": "voice", "settings": { "row": "bottom", "text": "オンシーズンはハードで体重管理が難しい", "attr": "20代 プロバレーボール選手" } },
        { "type": "voice", "settings": { "row": "bottom", "text": "調理が苦手で栄養に偏りが生じる", "attr": "20代 社会人硬式野球部選手" } },
        { "type": "voice", "settings": { "row": "bottom", "text": "自分で食事を準備するのは大変", "attr": "20代 社会人硬式野球部選手" } },
        { "type": "voice", "settings": { "row": "bottom", "text": "時間が無くてコンビニで済ませてしまうことがある", "attr": "20代 社会人硬式野球部選手" } }
      ]
    }
  ]
}
{% endschema %}
