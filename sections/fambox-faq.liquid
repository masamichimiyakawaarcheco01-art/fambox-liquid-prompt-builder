<!-- ============================================
     FAMBOX FAQ Section
     sections/fambox-faq.liquid
     WF: preview-faq.html
     ============================================ -->
{%- liquid
  assign sec_id = 'fambox-faq-' | append: section.id
-%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@600&display=swap');

  /* ============================================
     RESET: テーマCSS干渉対策
     ============================================ */
  #{{ sec_id }},
  #{{ sec_id }} *,
  #{{ sec_id }} *::before,
  #{{ sec_id }} *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ============================================
     SECTION BASE
     ============================================ */
  #{{ sec_id }} {
    position: relative;
    z-index: 1; /* ヘッダー(z-index:3-4)より下に配置 */
    width: 100%;
    background: {{ section.settings.bg_color }};
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ============================================
     INNER: padding で余白管理（空div不使用）
     ============================================ */
  #{{ sec_id }} .faq__inner {
    padding-top: 120px;
    padding-bottom: 120px;
  }

  /* ============================================
     TITLE AREA: max-width 1440px, 左64px
     ============================================ */
  #{{ sec_id }} .faq__title-area {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 64px;
  }
  #{{ sec_id }} .faq__title {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-size: 40px !important;
    font-weight: 500 !important;
    line-height: 180% !important;
    color: #1B1D1A !important;
    letter-spacing: normal !important;
    text-transform: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* ============================================
     SCROLL AREA: 全幅、手動スワイプ
     ============================================ */
  #{{ sec_id }} .faq__scroll-area {
    width: 100%;
    margin-top: 56px;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }
  #{{ sec_id }} .faq__scroll-area::-webkit-scrollbar {
    display: none;
  }

  /* ============================================
     SCROLL TRACK: flex row
     1440px時: 左64px + 320×4 + 32×3 = 1440px（右余白0px）
     1440px以上: 左余白を中央寄せ+64pxで調整
     ============================================ */
  #{{ sec_id }} .faq__scroll-track {
    display: flex;
    gap: 32px;
    padding-left: max(64px, calc((100% - 1440px) / 2 + 64px));
    padding-right: max(0px, calc((100% - 1440px) / 2));
  }

  /* ============================================
     FAQ CARD: 320px幅
     ============================================ */
  #{{ sec_id }} .faq__card {
    flex: 0 0 320px;
    width: 320px;
    background: #fff;
    padding: 24px;
    border-radius: 0;
  }

  /* ============================================
     AVATAR: 40×40
     ============================================ */
  #{{ sec_id }} .faq__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }
  #{{ sec_id }} .faq__avatar img {
    width: 40px;
    height: 40px;
    display: block;
    object-fit: cover;
  }
  #{{ sec_id }} .faq__avatar-placeholder {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #ddd;
    display: block !important;
  }

  /* ============================================
     QUESTION NUMBER: Poppins Semi Bold 24px
     ============================================ */
  #{{ sec_id }} .faq__q-number {
    font-family: 'Poppins', sans-serif !important;
    font-weight: 600 !important;
    font-size: 24px !important;
    color: #1B1D1A !important;
    line-height: 1 !important;
    margin-top: 16px !important;
    letter-spacing: normal !important;
    text-transform: none !important;
  }

  /* ============================================
     QUESTION TEXT: W6 18px 行間170%
     ============================================ */
  #{{ sec_id }} .faq__question {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-weight: 600 !important;
    font-size: 18px !important;
    color: #1B1D1A !important;
    line-height: 170% !important;
    margin-top: 24px !important;
  }

  /* ============================================
     DIVIDER LINE: 32px × 2px #1B1D1A
     div:empty対策: Liquidコメント挿入
     ============================================ */
  #{{ sec_id }} .faq__line {
    width: 32px !important;
    height: 2px !important;
    background: #1B1D1A !important;
    margin-top: 24px !important;
    display: block !important;
  }

  /* ============================================
     ANSWER TEXT: W5 18px #FC5214 行間170%
     ============================================ */
  #{{ sec_id }} .faq__answer {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-weight: 500 !important;
    font-size: 18px !important;
    color: #FC5214 !important;
    line-height: 170% !important;
    margin-top: 24px !important;
  }

  /* ============================================
     FAMBOX LOGO: SVG 高さ32px
     ============================================ */
  #{{ sec_id }} .faq__logo {
    margin-top: 32px !important;
    height: 32px;
    display: flex;
    align-items: center;
  }
  #{{ sec_id }} .faq__logo svg,
  #{{ sec_id }} .faq__logo img {
    height: 32px;
    width: auto;
    display: block;
  }

  /* ============================================
     SP LAYOUT (max-width: 767px)
     ============================================ */
  @media (max-width: 767px) {
    /* タイトル: 左24px */
    #{{ sec_id }} .faq__title-area {
      padding: 0 24px;
    }
    #{{ sec_id }} .faq__title {
      font-size: 28px !important;
      font-weight: 500 !important;
    }

    /* スクロール: スナップ */
    #{{ sec_id }} .faq__scroll-area {
      scroll-snap-type: x mandatory;
      scroll-padding-left: 24px;
    }
    #{{ sec_id }} .faq__scroll-track {
      padding-left: 24px;
      padding-right: 0;
    }
    /* 最後のカードが左寄せスナップできるよう右側にダミースペース */
    #{{ sec_id }} .faq__scroll-track::after {
      content: '';
      flex: 0 0 1px;
      width: 1px;
      padding-right: calc(100vw - (100vw - 96px) - 32px - 1px);
    }

    /* カード: スナップ＋チラ見え */
    #{{ sec_id }} .faq__card {
      flex: 0 0 calc(100vw - 96px);
      width: calc(100vw - 96px);
      scroll-snap-align: start;
      scroll-snap-stop: always;
    }

    /* 質問・回答: 16px */
    #{{ sec_id }} .faq__question {
      font-size: 16px !important;
    }
    #{{ sec_id }} .faq__answer {
      font-size: 16px !important;
    }
  }
</style>

<section id="{{ sec_id }}">
  <div class="faq__inner">

    <!-- ========================================
         TITLE AREA
         ======================================== -->
    <div class="faq__title-area">
      <h2 class="faq__title">{{ section.settings.title | newline_to_br }}</h2>
    </div>

    <!-- ========================================
         SCROLL AREA
         ======================================== -->
    <div class="faq__scroll-area">
      <div class="faq__scroll-track">

        {%- for block in section.blocks -%}
          {%- if block.type == 'faq_item' -%}
            <div class="faq__card" {{ block.shopify_attributes }}>

              <!-- ユーザ画像 40×40 -->
              <div class="faq__avatar">
                {%- if block.settings.avatar != blank -%}
                  {{ block.settings.avatar | image_url: width: 160 | image_tag:
                    alt: '',
                    width: 40,
                    height: 40,
                    loading: 'lazy'
                  }}
                {%- else -%}
                  <span class="faq__avatar-placeholder">{%- comment -%}not empty{%- endcomment -%}</span>
                {%- endif -%}
              </div>

              <!-- Question番号 -->
              <p class="faq__q-number">{{ block.settings.q_number }}</p>

              <!-- 質問文 -->
              <p class="faq__question">{{ block.settings.question | newline_to_br }}</p>

              <!-- 黒線（div:empty対策） -->
              <div class="faq__line">{%- comment -%}not empty{%- endcomment -%}</div>

              <!-- 回答文 -->
              <p class="faq__answer">{{ block.settings.answer | newline_to_br }}</p>

              <!-- FAMBOXロゴ -->
              <div class="faq__logo">
                {%- if section.settings.logo_svg != blank -%}
                  {{ section.settings.logo_svg }}
                {%- elsif section.settings.logo_image != blank -%}
                  {{ section.settings.logo_image | image_url: width: 200 | image_tag:
                    alt: 'FAMBOX',
                    loading: 'lazy'
                  }}
                {%- endif -%}
              </div>

            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "FAQ セクション",
  "tag": "section",
  "class": "fambox-faq-section",
  "settings": [
    {
      "type": "header",
      "content": "全体設定"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#fafafa"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "セクションタイトル（改行可）",
      "default": "購入前の不安、ここで解消\nFAQ"
    },
    {
      "type": "header",
      "content": "── FAMBOXロゴ ──"
    },
    {
      "type": "html",
      "id": "logo_svg",
      "label": "ロゴSVG（画像より優先）"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "ロゴ画像（SVG未設定時に使用）"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ項目",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "ユーザ画像（40×40推奨）"
        },
        {
          "type": "text",
          "id": "q_number",
          "label": "質問番号（例: Question 1）",
          "default": "Question 1"
        },
        {
          "type": "textarea",
          "id": "question",
          "label": "質問文",
          "default": "FAMBOXはどのような食事ですか？"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "回答文",
          "default": "FAMBOXはスポーツ栄養学に基づいた冷凍宅配食です。アスリートの目標に合わせた栄養バランスで設計されています。"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ セクション",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "q_number": "Question 1",
            "question": "FAMBOXはどのような食事ですか？",
            "answer": "FAMBOXはスポーツ栄養学に基づいた冷凍宅配食です。アスリートの目標に合わせた栄養バランスで設計されています。"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "q_number": "Question 2",
            "question": "最低注文数はありますか？",
            "answer": "法人プランの場合、最低10食からご注文いただけます。チーム規模に応じた柔軟なプランをご用意しています。"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "q_number": "Question 3",
            "question": "アレルギー対応はしていますか？",
            "answer": "主要なアレルゲンについてはメニューごとに表示しています。個別のご相談も承っておりますのでお気軽にお問い合わせください。"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "q_number": "Question 4",
            "question": "配送エリアに制限はありますか？",
            "answer": "全国配送に対応しています。冷凍便でお届けするため、届いたらそのまま冷凍庫で保管いただけます。"
          }
        }
      ]
    }
  ]
}
{% endschema %}
