{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{% comment %} === FAM Custom Footer V2 === {% endcomment %}
{%- liquid
  assign has_sns = false
  if section.settings.sns_instagram != blank or section.settings.sns_youtube != blank or section.settings.sns_note != blank or section.settings.sns_tiktok != blank or section.settings.sns_linktree != blank
    assign has_sns = true
  endif
-%}

{%- comment -%} デフォルトのコーナーSVG {%- endcomment -%}
{%- capture default_corner_svg -%}
<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 64 64" fill="none" aria-hidden="true">
  <rect x="28.5859" width="6.82667" height="64" fill="#FC825B"/>
  <rect y="35.4141" width="6.82667" height="64" transform="rotate(-90 0 35.4141)" fill="#FC825B"/>
  <path d="M35.4141 14.9277C35.4141 22.4683 41.5269 28.581 49.0674 28.5811H35.4141V14.9277Z" fill="#FC825B"/>
  <path d="M28.5938 49.0645C28.5938 41.5239 22.4809 35.4111 14.9404 35.4111L28.5938 35.4111L28.5938 49.0645Z" fill="#FC825B"/>
  <path d="M49.0703 35.4082C41.5298 35.4082 35.417 41.521 35.417 49.0615L35.417 35.4082L49.0703 35.4082Z" fill="#FC825B"/>
  <path d="M14.9375 28.584C22.478 28.584 28.5908 22.4712 28.5908 14.9307L28.5908 28.584L14.9375 28.584Z" fill="#FC825B"/>
</svg>
{%- endcapture -%}

<footer class="fam-footer-v2">
  <div class="fam-footer-v2__main">

    <!-- 左上 -->
    <div class="fam-footer-v2__corner fam-footer-v2__corner--tl">
      {%- if section.settings.corner_icon != blank -%}
        <img src="{{ section.settings.corner_icon | image_url: width: 128 }}" alt="" width="64" height="64">
      {%- else -%}
        {{ default_corner_svg }}
      {%- endif -%}
    </div>
    <!-- 左下 -->
    <div class="fam-footer-v2__corner fam-footer-v2__corner--bl">
      {%- if section.settings.corner_icon != blank -%}
        <img src="{{ section.settings.corner_icon | image_url: width: 128 }}" alt="" width="64" height="64">
      {%- else -%}
        {{ default_corner_svg }}
      {%- endif -%}
    </div>
    <!-- 右上 -->
    <div class="fam-footer-v2__corner fam-footer-v2__corner--tr">
      {%- if section.settings.corner_icon != blank -%}
        <img src="{{ section.settings.corner_icon | image_url: width: 128 }}" alt="" width="64" height="64">
      {%- else -%}
        {{ default_corner_svg }}
      {%- endif -%}
    </div>
    <!-- 右下 -->
    <div class="fam-footer-v2__corner fam-footer-v2__corner--br">
      {%- if section.settings.corner_icon != blank -%}
        <img src="{{ section.settings.corner_icon | image_url: width: 128 }}" alt="" width="64" height="64">
      {%- else -%}
        {{ default_corner_svg }}
      {%- endif -%}
    </div>

    <div class="fam-footer-v2__inner">
      <div class="fam-footer-v2__content">

        <!-- Brand -->
        <div class="fam-footer-v2__brand">
          {%- if section.settings.footer_logo != blank -%}
            {%- assign flogo = section.settings.footer_logo -%}
            {%- assign flogo_h = section.settings.footer_logo_width | divided_by: flogo.aspect_ratio -%}
            <img
              src="{{ flogo | image_url: width: 400 }}"
              alt="{{ shop.name }}"
              class="fam-footer-v2__logo"
              width="{{ section.settings.footer_logo_width }}"
              height="{{ flogo_h }}"
              loading="lazy"
            >
          {%- endif -%}
          {%- if section.settings.footer_tagline != blank -%}
            <p class="fam-footer-v2__tagline">{{ section.settings.footer_tagline }}</p>
          {%- endif -%}
        </div>

        <!-- Navigation -->
        <div class="fam-footer-v2__nav">
          {%- for block in section.blocks -%}
            {%- if block.type == 'link_list' and block.settings.menu != blank -%}
              {%- if block.settings.menu.links.size <= 7 -%}
                <div class="fam-footer-v2__nav-col" {{ block.shopify_attributes }}>
                  {%- for link in block.settings.menu.links -%}
                    <a href="{{ link.url }}" class="fam-footer-v2__link">
                      <span>{{ link.title }}</span>
                      <svg class="fam-footer-v2__arrow" width="20" height="12" viewBox="0 0 20 12" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 6h18M13 1l5 5-5 5" stroke="currentColor" stroke-width="1.2"/></svg>
                    </a>
                  {%- endfor -%}
                </div>

                {%- if has_sns -%}
                <div class="fam-footer-v2__nav-col fam-footer-v2__nav-col--sns">
                  <div class="fam-footer-v2__social">
                    <ul class="fam-footer-v2__social-list">
