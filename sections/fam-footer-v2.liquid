              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

      </div>

      <!-- 装飾画像（右50%中央） -->
      {%- if section.settings.footer_deco_image != blank -%}
        <div class="fam-footer-v2__deco" aria-hidden="true">
          {%- assign deco_img = section.settings.footer_deco_image -%}
          {%- assign deco_h = 800 | divided_by: deco_img.aspect_ratio -%}
          <img
            src="{{ deco_img | image_url: width: 800 }}"
            alt=""
            width="800"
            height="{{ deco_h }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}

    </div>
  </div>

  <!-- ===== ボトムバー ===== -->
  <div class="fam-footer-v2__bottom">
    <div class="fam-footer-v2__bottom-inner">
      <small>&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url -}}</small>
    </div>
  </div>
</footer>

<style>
/* ========================
   FAM Footer V2
   ======================== */
.fam-footer-v2__main {
  position: relative;
  background: #FB4C15;
  overflow: hidden;
}
.fam-footer-v2__inner {
  position: relative;
  z-index: 1;
  max-width: 1440px;
  margin: 0 auto;
  overflow: hidden;
  padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 0 {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px 50px;
}
@media screen and (min-width: 750px) {
  .fam-footer-v2 {
    margin-top: {{ section.settings.margin_top }}px;
  }
  .fam-footer-v2__inner {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 50px;
  }
}
.fam-footer-v2__content {
  max-width: calc(50% - 50px);
}

/* ========================
   四隅コーナーアイコン
   ======================== */
.fam-footer-v2__corner {
  position: absolute;
  width: 64px;
  height: 64px;
  pointer-events: none;
  z-index: 2;
}
.fam-footer-v2__corner svg,
.fam-footer-v2__corner img {
  width: 64px;
  height: 64px;
  display: block;
}
.fam-footer-v2__corner--tl { top: 0; left: 0; }
.fam-footer-v2__corner--bl { bottom: 0; left: 0; }
.fam-footer-v2__corner--tr { top: 0; right: 0; }
.fam-footer-v2__corner--br { bottom: 0; right: 0; }

/* ========================
   Brand
   ======================== */
.fam-footer-v2__brand {
  margin-bottom: 28px;
}
.fam-footer-v2__logo {
  display: block;
  height: auto;
  width: auto;
  max-height: 40px;
  margin-bottom: 12px;
}
.fam-footer-v2__tagline {
  margin: 0;
  font-family: "Poppins", sans-serif;
  font-size: 24px;
  font-style: normal;
  font-weight: 500;
  line-height: 170%;
  letter-spacing: 1px;
  color: #fff;
  opacity: 0.3;
}

/* ========================
   Nav
   ======================== */
.fam-footer-v2__nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0 40px;
  border-top: 1px solid rgba(255,255,255,0.2);
}

/* ========================
   Links
   ======================== */
.fam-footer-v2__link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 0;
  border-bottom: 1px solid rgba(255,255,255,0.2);
  color: #fff;
  text-decoration: none;
  font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", sans-serif;
  font-size: 14px;
  font-weight: 600;
  line-height: 1.5;
  transition: opacity 0.2s;
}
.fam-footer-v2__link:hover {
  opacity: 0.7;
}
.fam-footer-v2__arrow {
  flex-shrink: 0;
  width: 16px;
  height: 10px;
  margin-left: 12px;
}

/* ========================
   Social
   ======================== */
.fam-footer-v2__social {
  padding-top: 24px;
}
.fam-footer-v2__social-list {
  display: flex;
  justify-content: space-between;
  list-style: none;
  padding: 0;
  margin: 0;
}
.fam-footer-v2__social-list a {
  color: #fff;
  display: block;
  transition: opacity 0.2s;
}
.fam-footer-v2__social-list a:hover {
  opacity: 0.7;
}
.fam-footer-v2__social-list svg {
  display: block;
  width: 40px;
  height: 40px;
}

/* ========================
   右装飾画像
   ======================== */
.fam-footer-v2__deco {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 0;
}
.fam-footer-v2__deco img {
  width: 280px;
  height: 310px;
  aspect-ratio: 28 / 31;
  object-fit: contain;
  display: block;
}

/* ========================
   ボトムバー
   ======================== */
.fam-footer-v2__bottom {
  background: #1B1D1A;
  padding: 16px 0;
  text-align: center;
}
.fam-footer-v2__bottom-inner {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 50px;
}
.fam-footer-v2__bottom small {
  font-size: 12px;
  color: rgba(255,255,255,0.55);
  font-family: "Hiragino Sans", sans-serif;
}
.fam-footer-v2__bottom a {
  color: rgba(255,255,255,0.55);
  text-decoration: none;
}

/* ========================
   SP
   ======================== */
@media (max-width: 767px) {
  .fam-footer-v2__inner {
    padding-left: 20px;
    padding-right: 20px;
  }
  .fam-footer-v2__content {
    max-width: none;
  }
  .fam-footer-v2__tagline {
    font-size: 16px;
  }
  .fam-footer-v2__nav {
    grid-template-columns: 1fr;
    gap: 0;
  }
  .fam-footer-v2__social-list {
    justify-content: center;
    gap: 30px;
  }
  .fam-footer-v2__nav-col + .fam-footer-v2__nav-col .fam-footer-v2__link:first-child {
    border-top: none;
  }
  .fam-footer-v2__deco {
    display: none;
  }
  /* SP: 四隅すべて非表示 */
  .fam-footer-v2__corner {
    display: none;
  }
  .fam-footer-v2__link {
    font-size: 13px;
    padding: 12px 0;
  }
  .fam-footer-v2__bottom-inner {
    padding: 0 20px;
  }
}
</style>

