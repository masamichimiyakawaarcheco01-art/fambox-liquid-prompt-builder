{%- assign sec_id = 'fambox-spirit-' | append: section.id -%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap');

  /* =============================================
     SECTION: 720px
     ============================================= */
  #{{ sec_id }} .fam-spirit {
    width: 100%;
    height: auto;
    background: {{ section.settings.bg_color }};
    position: relative;
    z-index: 1; /* ヘッダー(z-index:3-4)より下に配置 */
    overflow: hidden;
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', sans-serif !important;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* =============================================
     BACKGROUND TEXTURE
     ============================================= */
  #{{ sec_id }} .spirit-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  #{{ sec_id }} .spirit-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px;
  }

  /* =============================================
     HEARTBEAT BACKGROUND
     ============================================= */
  #{{ sec_id }} .spirit-heartbeat {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 0;
    height: 0;
    z-index: 3;
    pointer-events: none;
  }
  #{{ sec_id }} .spirit-heartbeat__core {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    box-shadow: 0 0 100px 50px rgba(255,255,255,0.08), 0 0 250px 100px rgba(255,255,255,0.04);
    animation: hbCore-{{ section.id }} 8s ease-in-out infinite;
  }
  @keyframes hbCore-{{ section.id }} {
    0%, 100% { transform: translate(-50%,-50%) scale(1); box-shadow: 0 0 100px 50px rgba(255,255,255,0.08), 0 0 250px 100px rgba(255,255,255,0.04); }
    30% { transform: translate(-50%,-50%) scale(2); box-shadow: 0 0 150px 70px rgba(255,255,255,0.15), 0 0 300px 130px rgba(255,255,255,0.06); }
    50% { transform: translate(-50%,-50%) scale(1.2); box-shadow: 0 0 120px 55px rgba(255,255,255,0.1), 0 0 260px 110px rgba(255,255,255,0.05); }
    70% { transform: translate(-50%,-50%) scale(1.8); box-shadow: 0 0 140px 65px rgba(255,255,255,0.12), 0 0 280px 120px rgba(255,255,255,0.05); }
  }

  #{{ sec_id }} .spirit-heartbeat__ring {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    opacity: 0;
  }
  #{{ sec_id }} .spirit-heartbeat__ring--1 { animation: hbRing-{{ section.id }} 8s cubic-bezier(0.25, 0.1, 0.25, 1) infinite 0s; }
  #{{ sec_id }} .spirit-heartbeat__ring--2 { animation: hbRing-{{ section.id }} 8s cubic-bezier(0.25, 0.1, 0.25, 1) infinite 1.1s; }
  #{{ sec_id }} .spirit-heartbeat__ring--3 { animation: hbRing-{{ section.id }} 8s cubic-bezier(0.25, 0.1, 0.25, 1) infinite 2.2s; }
  #{{ sec_id }} .spirit-heartbeat__ring--4 { animation: hbRing-{{ section.id }} 8s cubic-bezier(0.25, 0.1, 0.25, 1) infinite 3.3s; }
  #{{ sec_id }} .spirit-heartbeat__ring--5 { animation: hbRing-{{ section.id }} 8s cubic-bezier(0.25, 0.1, 0.25, 1) infinite 4.4s; }
  #{{ sec_id }} .spirit-heartbeat__ring--6 { animation: hbRing-{{ section.id }} 8s cubic-bezier(0.25, 0.1, 0.25, 1) infinite 5.5s; }
  #{{ sec_id }} .spirit-heartbeat__ring--7 { animation: hbRing-{{ section.id }} 8s cubic-bezier(0.25, 0.1, 0.25, 1) infinite 6.6s; }
  @keyframes hbRing-{{ section.id }} {
    0% { width: 16px; height: 16px; opacity: 0.4; border-width: 2px; }
    40% { opacity: 0.15; }
    100% { width: 1800px; height: 1800px; opacity: 0; border-width: 0.5px; }
  }

  #{{ sec_id }} .spirit-heartbeat__ecg {
    position: absolute;
    top: 0;
    left: -700px;
    width: 1400px;
    height: 1px;
    overflow: hidden;
    transform: translateY(-50%);
  }
  #{{ sec_id }} .spirit-heartbeat__ecg::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent 30%, rgba(255,255,255,0.06) 50%, transparent 70%);
    animation: hbEcg-{{ section.id }} 12s linear infinite;
  }
  @keyframes hbEcg-{{ section.id }} {
    0% { left: -100%; }
    100% { left: 200%; }
  }

  #{{ sec_id }} .spirit-heartbeat__glow {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.04) 40%, transparent 65%);
    animation: hbGlow-{{ section.id }} 12s ease-in-out infinite;
  }
  @keyframes hbGlow-{{ section.id }} {
    0%, 100% { transform: translate(-50%,-50%) scale(1); opacity: 0.3; }
    50% { transform: translate(-50%,-50%) scale(1.5); opacity: 0.7; }
  }

  /* =============================================
     SECTION TITLE (左寄せ、1440px制約)
     ============================================= */
  #{{ sec_id }} .spirit-section-title {
    position: relative;
    z-index: 5;
    max-width: 1440px;
    width: 100%;
    margin: 0 auto;
    padding: 120px 64px 24px 64px;
    text-align: left;
  }
  #{{ sec_id }} .spirit-section-title__text {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', sans-serif !important;
    font-size: 40px !important;
    font-weight: 500 !important;
    line-height: 180% !important;
    color: #fff !important;
    display: block !important;
    letter-spacing: normal !important;
    text-transform: none !important;
  }

  /* =============================================
     HEADER
     ============================================= */
  #{{ sec_id }} .spirit-header {
    position: relative;
    z-index: 5;
    text-align: center;
    margin-bottom: 56px;
  }
  #{{ sec_id }} .spirit-header__kicker {
    font-family: 'Poppins', sans-serif !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.45) !important;
    text-transform: uppercase;
    margin-bottom: 16px;
    line-height: 1.5 !important;
    display: block !important;
  }
  #{{ sec_id }} .spirit-header__title {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', sans-serif !important;
    font-size: 32px !important;
    font-weight: 600 !important;
    line-height: 180% !important;
    color: #fff !important;
    display: block !important;
  }

  /* =============================================
     CAROUSEL
     ============================================= */
  #{{ sec_id }} .spirit-carousel {
    position: relative;
    z-index: 5;
    width: 100%;
    height: 520px;
    perspective: 1200px;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    touch-action: pan-y;
    -ms-touch-action: pan-y;
  }
  #{{ sec_id }} .spirit-carousel:active { cursor: grabbing; }

  #{{ sec_id }} .spirit-carousel__track {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 100%;
  }

  /* =============================================
     CARD
     ============================================= */
  #{{ sec_id }} .spirit-card {
    position: absolute;
    width: 480px;
    height: 480px;
    overflow: hidden;
    display: flex !important;
    flex-direction: column;
    justify-content: flex-start;
    cursor: pointer;
    transition: transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
                opacity 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
                filter 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
                box-shadow 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
                width 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
                height 0.6s cubic-bezier(0.25, 0.1, 0.25, 1),
                left 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform, opacity, filter, left;
  }

  /* Card image */
  #{{ sec_id }} .spirit-card__image {
    margin-top: auto;
    width: 100%;
    height: 200px;
    overflow: hidden;
    flex-shrink: 0;
  }
  #{{ sec_id }} .spirit-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block !important;
  }
  #{{ sec_id }} .spirit-card__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(251,76,21,0.08) 0%, rgba(251,76,21,0.02) 100%);
    display: flex !important;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.15) !important;
    font-size: 12px !important;
  }

  /* CENTER card */
  #{{ sec_id }} .spirit-card[data-pos="0"] {
    z-index: 10;
    opacity: 1;
    filter: blur(0);
    box-shadow: 0 40px 80px -20px rgba(0,0,0,0.4);
    transform: translate(-50%, -50%) scale(1);
  }

  /* +/-1 */
  #{{ sec_id }} .spirit-card[data-pos="1"],
  #{{ sec_id }} .spirit-card[data-pos="-1"] {
    z-index: 8;
    opacity: 0.5;
    filter: blur(0);
    box-shadow: none;
    transform: translate(-50%, -50%) scale(1);
  }

  /* +/-2 */
  #{{ sec_id }} .spirit-card[data-pos="2"],
  #{{ sec_id }} .spirit-card[data-pos="-2"] {
    z-index: 6;
    opacity: 0.2;
    filter: blur(0);
    box-shadow: none;
    transform: translate(-50%, -50%) scale(1);
  }

  /* +/-3: fade out */
  #{{ sec_id }} .spirit-card[data-pos="3"],
  #{{ sec_id }} .spirit-card[data-pos="-3"] {
    z-index: 4;
    opacity: 0;
    filter: blur(0);
    box-shadow: none;
    transform: translate(-50%, -50%) scale(1);
    pointer-events: none;
  }

  /* =============================================
     CARD CONTENT
     ============================================= */
  #{{ sec_id }} .spirit-card__content {
    position: relative;
    z-index: 2;
    padding: 36px 32px;
  }
  #{{ sec_id }} .spirit-card__index {
    font-family: 'Poppins', sans-serif !important;
    font-size: 11px !important;
    font-weight: 600 !important;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.5) !important;
    line-height: 1.5 !important;
    margin-bottom: 16px;
    text-transform: uppercase;
    display: block !important;
  }
  #{{ sec_id }} .spirit-card__line {
    width: 32px;
    height: 2px;
    background: #FB4C15;
    margin-bottom: 16px;
    opacity: 0.5;
    transition: width 0.5s ease, opacity 0.5s ease;
  }
  #{{ sec_id }} .spirit-card[data-pos="0"] .spirit-card__line {
    width: 48px;
    opacity: 1;
  }
  #{{ sec_id }} .spirit-card__title {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', sans-serif !important;
    font-size: 24px !important;
    font-weight: 600 !important;
    line-height: 170% !important;
    color: #fff !important;
    margin-bottom: 12px;
    text-shadow: 0 1px 4px rgba(0,0,0,0.2);
    display: block !important;
  }
  #{{ sec_id }} .spirit-card__body {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', sans-serif !important;
    font-size: 16px !important;
    font-weight: 400 !important;
    line-height: 180% !important;
    color: rgba(255,255,255,0.8) !important;
    text-shadow: 0 1px 3px rgba(0,0,0,0.15);
    display: block !important;
  }

  /* =============================================
     NAV DOTS
     ============================================= */
  #{{ sec_id }} .spirit-dots {
    position: relative;
    z-index: 5;
    display: flex !important;
    gap: 10px;
    margin-top: 24px;
    margin-bottom: 120px;
  }
  #{{ sec_id }} .spirit-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    cursor: pointer;
    transition: all 0.4s ease;
    border: none;
    padding: 0;
  }
  #{{ sec_id }} .spirit-dot--active {
    background: #fff;
    width: 24px;
    border-radius: 4px;
  }

  /* =============================================
     SP
     ============================================= */
  @media (max-width: 767px) {
    #{{ sec_id }} .fam-spirit {
      height: auto;
      min-height: 560px;
      padding: 40px 0;
    }
    #{{ sec_id }} .spirit-section-title {
      padding: 80px 24px 8px 24px;
    }
    #{{ sec_id }} .spirit-dots {
      margin-bottom: 80px;
    }
    #{{ sec_id }} .spirit-section-title__text {
      font-size: 28px !important;
    }
    #{{ sec_id }} .spirit-header__title {
      font-size: 24px !important;
    }
    #{{ sec_id }} .spirit-carousel {
      height: 564px;
    }
    #{{ sec_id }} .spirit-card {
      width: 284px;
      height: 504px;
    }
    #{{ sec_id }} .spirit-card[data-pos="0"] {
      width: 284px;
      height: 504px;
    }
    #{{ sec_id }} .spirit-card__content {
      padding: 28px 24px;
    }
    #{{ sec_id }} .spirit-card__title {
      font-size: 20px !important;
    }
    #{{ sec_id }} .spirit-card__body {
      font-size: 14px !important;
    }
  }

  /* =============================================
     REDUCED MOTION
     ============================================= */
  @media (prefers-reduced-motion: reduce) {
    #{{ sec_id }} *,
    #{{ sec_id }} *::before,
    #{{ sec_id }} *::after {
      animation: none !important;
      transition-duration: 0s !important;
    }
  }
</style>

<div id="{{ sec_id }}">
  <section class="fam-spirit">
    <!-- SECTION TITLE -->
    <div class="spirit-section-title">
      <h2 class="spirit-section-title__text">{{ section.settings.section_title | newline_to_br }}</h2>
    </div>

    <div class="spirit-bg">{%- comment -%}not empty{%- endcomment -%}</div>

    <!-- HEARTBEAT -->
    <div class="spirit-heartbeat">
      <div class="spirit-heartbeat__glow">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__core">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__ring spirit-heartbeat__ring--1">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__ring spirit-heartbeat__ring--2">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__ring spirit-heartbeat__ring--3">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__ring spirit-heartbeat__ring--4">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__ring spirit-heartbeat__ring--5">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__ring spirit-heartbeat__ring--6">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__ring spirit-heartbeat__ring--7">{%- comment -%}not empty{%- endcomment -%}</div>
      <div class="spirit-heartbeat__ecg">{%- comment -%}not empty{%- endcomment -%}</div>
    </div>

    <div class="spirit-carousel" id="spiritCarousel-{{ section.id }}">
      <div class="spirit-carousel__track" id="spiritTrack-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="spirit-card" data-idx="{{ forloop.index0 }}" style="background: {{ block.settings.card_bg_color }};" {{ block.shopify_attributes }}>
            <div class="spirit-card__content">
              <div class="spirit-card__index">{{ block.settings.index_label }}</div>
              <div class="spirit-card__line">{%- comment -%}not empty{%- endcomment -%}</div>
              <div class="spirit-card__title">{{ block.settings.card_title }}</div>
              <div class="spirit-card__body">{{ block.settings.card_body }}</div>
            </div>
            <div class="spirit-card__image">
              {%- if block.settings.card_image != blank -%}
                {{ block.settings.card_image | image_url: width: 680 | image_tag }}
              {%- else -%}
                <div class="spirit-card__image-placeholder">IMAGE</div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="spirit-dots" id="spiritDots-{{ section.id }}">{%- comment -%}not empty{%- endcomment -%}</div>
  </section>
</div>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var autoInterval = {{ section.settings.autoplay_interval | default: 6000 }};
  var track = document.getElementById('spiritTrack-' + sectionId);
  var dotsContainer = document.getElementById('spiritDots-' + sectionId);
  var carousel = document.getElementById('spiritCarousel-' + sectionId);

  if (!track || !dotsContainer || !carousel) return;

  var cardEls = track.querySelectorAll('.spirit-card');
  var total = cardEls.length;
  if (total === 0) return;

  var current = 0;
  var isAnimating = false;

  // Dot generation
  for (var i = 0; i < total; i++) {
    var dot = document.createElement('button');
    dot.className = 'spirit-dot';
    dot.dataset.idx = i;
    dot.setAttribute('aria-label', 'Go to card ' + (i + 1));
    (function(idx) {
      dot.addEventListener('click', function() {
        if (isAnimating) return;
        goTo(idx);
      });
    })(i);
    dotsContainer.appendChild(dot);
  }

  function getSpacing() {
    return window.innerWidth <= 767 ? 316 : 512;
  }

  function goTo(idx) {
    current = idx;
    render();
  }

  function render() {
    var spacing = getSpacing();

    cardEls.forEach(function(el) {
      var idx = parseInt(el.dataset.idx);
      var diff = idx - current;

      // wrap
      if (diff > total / 2) diff -= total;
      if (diff < -total / 2) diff += total;

      var absDiff = Math.abs(diff);
      var posX = diff * spacing;

      el.dataset.pos = Math.max(-3, Math.min(3, diff));
      el.style.left = 'calc(50% + ' + posX + 'px)';
      el.style.top = '50%';

      if (absDiff > 3) {
        el.style.visibility = 'hidden';
        el.style.pointerEvents = 'none';
      } else {
        el.style.visibility = '';
        el.style.pointerEvents = 'auto';
      }
    });

    // dots
    var dots = dotsContainer.querySelectorAll('.spirit-dot');
    dots.forEach(function(d, i) {
      d.classList.toggle('spirit-dot--active', i === current);
    });
  }

  // Drag / swipe
  var startX = 0;
  var startY = 0;
  var isDragging = false;
  var dragDelta = 0;
  var isHorizontal = null;
  var wasDragged = false;

  carousel.addEventListener('pointerdown', function(e) {
    startX = e.clientX;
    startY = e.clientY;
    isDragging = true;
    dragDelta = 0;
    wasDragged = false;
    isHorizontal = null;
    carousel.setPointerCapture(e.pointerId);
  });

  carousel.addEventListener('pointermove', function(e) {
    if (!isDragging) return;

    var dx = e.clientX - startX;
    var dy = e.clientY - startY;

    var detectThreshold = window.innerWidth <= 767 ? 3 : 8;
    if (isHorizontal === null && (Math.abs(dx) > detectThreshold || Math.abs(dy) > detectThreshold)) {
      isHorizontal = Math.abs(dx) > Math.abs(dy);
    }

    if (isHorizontal === false) return;

    // 横スワイプ確定: ブラウザのデフォルト動作を停止
    e.preventDefault();

    if (Math.abs(dx) > detectThreshold) wasDragged = true;
    dragDelta = dx;

    var spacing = getSpacing();
    cardEls.forEach(function(el) {
      var idx = parseInt(el.dataset.idx);
      var diff = idx - current;
      if (diff > total / 2) diff -= total;
      if (diff < -total / 2) diff += total;
      var posX = diff * spacing + dragDelta;
      el.style.transition = 'none';
      el.style.left = 'calc(50% + ' + posX + 'px)';
    });
  });

  carousel.addEventListener('pointerup', function(e) {
    if (!isDragging) return;
    isDragging = false;

    cardEls.forEach(function(el) {
      el.style.transition = '';
    });

    if (wasDragged) {
      var threshold = window.innerWidth <= 767 ? 8 : 40;
      if (dragDelta < -threshold) {
        current = (current + 1) % total;
      } else if (dragDelta > threshold) {
        current = (current - 1 + total) % total;
      }
      render();
      return;
    }

    // Click detection using elementFromPoint
    var clickedCard = document.elementFromPoint(e.clientX, e.clientY);
    if (clickedCard) {
      var card = clickedCard.closest('.spirit-card');
      if (card) {
        var clickedIdx = parseInt(card.dataset.idx);
        if (clickedIdx !== current) {
          stopAuto();
          var diff = clickedIdx - current;
          if (diff > total / 2) diff -= total;
          if (diff < -total / 2) diff += total;

          var step = diff > 0 ? 1 : -1;
          var stepsRemaining = Math.abs(diff);
          var stepInterval = setInterval(function() {
            current = (current + step + total) % total;
            render();
            stepsRemaining--;
            if (stepsRemaining <= 0) {
              clearInterval(stepInterval);
              startAuto();
            }
          }, 180);
        }
      }
    }
  });

  carousel.addEventListener('pointercancel', function() {
    isDragging = false;
    cardEls.forEach(function(el) { el.style.transition = ''; });
    render();
  });

  // SP: touchmoveをpassive:falseで登録し、横スワイプ時にブラウザスクロールを確実に抑制
  carousel.addEventListener('touchmove', function(e) {
    if (isDragging && isHorizontal) {
      e.preventDefault();
    }
  }, { passive: false });

  // Keyboard
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight') { current = (current + 1) % total; render(); }
    if (e.key === 'ArrowLeft') { current = (current - 1 + total) % total; render(); }
  });

  // Auto-play
  var autoTimer;
  function startAuto() {
    if (autoInterval <= 0) return;
    autoTimer = setInterval(function() {
      current = (current + 1) % total;
      render();
    }, autoInterval);
  }
  function stopAuto() { clearInterval(autoTimer); }

  carousel.addEventListener('mouseenter', stopAuto);
  carousel.addEventListener('mouseleave', startAuto);

  render();
  startAuto();
  window.addEventListener('resize', render);
})();
</script>

{% schema %}
{
  "name": "FAM Spirit Carousel",
  "tag": "section",
