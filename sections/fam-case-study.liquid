{% comment %}
  fam-case-study.liquid
  FAM 導入事例セクション - ブログ記事テンプレート用
  カスタマイザーでブロックを追加・並び替えして構成します
{% endcomment %}
<style>
#fam-case-study-{{ section.id }} {
  --fcs-orange: #FB4C15;
  --fcs-dark: #1B1D1A;
  --fcs-gray: #888888;
  --fcs-light: #f3f3f3;
  --fcs-border: rgba(0,0,0,0.1);
  --fcs-font-ja: "Hiragino Sans", "Hiragino Kaku Gothic ProN", sans-serif;
  --fcs-font-en: 'Poppins', sans-serif;
  background: {{ section.settings.bg_color }};
  color: {{ section.settings.text_color }};
  font-family: var(--fcs-font-ja);
  -webkit-font-smoothing: antialiased;
}
#fam-case-study-{{ section.id }} .fcs-wrap {
  max-width: 960px;
  margin: 0 auto;
  padding: {{ section.settings.padding_top }}px 56px {{ section.settings.padding_bottom }}px;
}
/* ===== THUMBNAIL ===== */
#fam-case-study-{{ section.id }} .fcs-thumbnail {
  width: 100%;
  margin-bottom: 56px;
}
#fam-case-study-{{ section.id }} .fcs-thumbnail__img-wrap {
  width: 100%;
  aspect-ratio: 16 / 9;
  background: var(--fcs-light);
  border-radius: 4px;
  overflow: hidden;
}
#fam-case-study-{{ section.id }} .fcs-thumbnail__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
#fam-case-study-{{ section.id }} .fcs-thumbnail__caption {
  font-size: 12px;
  color: var(--fcs-gray);
  text-align: center;
  margin-top: 8px;
}
/* ===== ARTICLE HEADER ===== */
#fam-case-study-{{ section.id }} .fcs-article-header {
  margin-bottom: 40px;
}
#fam-case-study-{{ section.id }} .fcs-eyebrow {
  font-family: var(--fcs-font-en);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--fcs-orange);
  display: block;
  margin-bottom: 14px;
}
#fam-case-study-{{ section.id }} .fcs-article-title {
  font-size: clamp(20px, 2.2vw, 28px);
  font-weight: 700;
  line-height: 1.5;
  letter-spacing: 0.02em;
  margin-bottom: 12px;
  white-space: pre-line;
}
#fam-case-study-{{ section.id }} .fcs-article-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 4px;
}
#fam-case-study-{{ section.id }} .fcs-article-subtitle {
  font-family: var(--fcs-font-en);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.12em;
  color: var(--fcs-gray);
}
#fam-case-study-{{ section.id }} .fcs-article-date {
  font-family: var(--fcs-font-en);
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.08em;
  color: var(--fcs-gray);
  display: flex;
  align-items: center;
  gap: 6px;
}
#fam-case-study-{{ section.id }} .fcs-article-date::before {
  content: '';
  display: inline-block;
  width: 1px;
  height: 12px;
  background: var(--fcs-border);
}
#fam-case-study-{{ section.id }} .fcs-article-date:first-child::before {
  display: none;
}
/* ===== LEAD ===== */
#fam-case-study-{{ section.id }} .fcs-lead {
  font-size: 16px;
  font-weight: 500;
  line-height: 1.95;
  color: #444;
  padding: 28px 0;
  border-top: 2px solid var(--fcs-dark);
  border-bottom: 1px solid var(--fcs-border);
  margin-bottom: 52px;
  white-space: pre-line;
}
/* ===== TEXT SECTION ===== */
#fam-case-study-{{ section.id }} .fcs-section {
  margin-bottom: 48px;
}
#fam-case-study-{{ section.id }} .fcs-section-heading {
  font-size: 17px;
  font-weight: 700;
  line-height: 1.5;
  letter-spacing: 0.02em;
  margin-bottom: 18px;
  padding-left: 16px;
  border-left: 3px solid var(--fcs-orange);
}
#fam-case-study-{{ section.id }} .fcs-section-body {
  font-size: 15px;
  font-weight: 400;
  line-height: 1.95;
  color: #333;
  white-space: pre-line;
}
/* ===== 2カラム ===== */
#fam-case-study-{{ section.id }} .fcs-cols {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 52px;
  align-items: start;
  margin-bottom: 48px;
}
#fam-case-study-{{ section.id }} .fcs-cols .fcs-col-img  { order: 2; }
#fam-case-study-{{ section.id }} .fcs-cols .fcs-col-text { order: 1; }
#fam-case-study-{{ section.id }} .fcs-cols.img-left .fcs-col-img  { order: 1; }
#fam-case-study-{{ section.id }} .fcs-cols.img-left .fcs-col-text { order: 2; }
/* ===== 画像共通ラッパー ===== */
#fam-case-study-{{ section.id }} .fcs-img-wrap {
  width: 100%;
  background: var(--fcs-light);
  border-radius: 4px;
  overflow: hidden;
}
#fam-case-study-{{ section.id }} .fcs-img-wrap--43  { aspect-ratio: 4 / 3; }
#fam-case-study-{{ section.id }} .fcs-img-wrap--169 { aspect-ratio: 16 / 9; }
#fam-case-study-{{ section.id }} .fcs-img-wrap--free { aspect-ratio: unset; }
#fam-case-study-{{ section.id }} .fcs-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
#fam-case-study-{{ section.id }} .fcs-img-wrap--free img {
  height: auto;
}
#fam-case-study-{{ section.id }} .fcs-img-caption {
  font-size: 12px;
  color: var(--fcs-gray);
  text-align: center;
  margin-top: 8px;
}
/* ===== 1カラム画像ブロック ===== */
#fam-case-study-{{ section.id }} .fcs-image-block {
  margin: 32px 0;
}
/* ===== 統計ボックス ===== */
#fam-case-study-{{ section.id }} .fcs-stat-row {
  display: flex;
  gap: 16px;
  margin: 32px 0;
  flex-wrap: wrap;
}
#fam-case-study-{{ section.id }} .fcs-stat {
  flex: 1;
  min-width: 140px;
  background: var(--fcs-dark);
  padding: 20px 24px;
  border-radius: 4px;
}
#fam-case-study-{{ section.id }} .fcs-stat__num {
  font-family: var(--fcs-font-en);
  font-size: 32px;
  font-weight: 700;
  color: var(--fcs-orange);
  line-height: 1;
  margin-bottom: 8px;
}
#fam-case-study-{{ section.id }} .fcs-stat__label {
  font-size: 12px;
  line-height: 1.6;
  color: rgba(255,255,255,0.6);
  white-space: pre-line;
}
/* ===== 引用 ===== */
#fam-case-study-{{ section.id }} .fcs-quote {
  margin: 28px 0;
  padding: 24px 28px 24px 48px;
  border: 1px solid var(--fcs-border);
  border-top: 3px solid var(--fcs-orange);
  border-radius: 0 0 4px 4px;
  position: relative;
  background: #fff;
}
#fam-case-study-{{ section.id }} .fcs-quote::before {
  content: '\201C';
  font-family: Georgia, serif;
  font-size: 56px;
  color: var(--fcs-orange);
  opacity: 0.2;
  position: absolute;
  top: 2px;
  left: 18px;
  line-height: 1;
}
#fam-case-study-{{ section.id }} .fcs-quote__text {
  font-size: 15px;
  font-weight: 500;
  line-height: 1.9;
  color: var(--fcs-dark);
  white-space: pre-line;
}
#fam-case-study-{{ section.id }} .fcs-quote__name {
  font-family: var(--fcs-font-en);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: var(--fcs-orange);
  display: block;
  margin-top: 10px;
}
/* ===== ハイライトボックス ===== */
#fam-case-study-{{ section.id }} .fcs-highlight {
  background: var(--fcs-light);
  border-left: 4px solid var(--fcs-orange);
  padding: 20px 24px;
  margin: 24px 0;
  border-radius: 0 4px 4px 0;
}
#fam-case-study-{{ section.id }} .fcs-highlight__text {
  font-size: 15px;
  font-weight: 500;
  line-height: 1.85;
  color: var(--fcs-dark);
  white-space: pre-line;
}
/* ===== チェックリスト ===== */
#fam-case-study-{{ section.id }} .fcs-checklist {
  list-style: none;
  margin: 20px 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
#fam-case-study-{{ section.id }} .fcs-checklist li {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 15px;
  line-height: 1.7;
  color: #333;
}
#fam-case-study-{{ section.id }} .fcs-checklist li::before {
  content: '';
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  margin-top: 2px;
  border-radius: 50%;
  background-color: var(--fcs-orange);
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M5 10L8.5 13.5L15 7' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-size: contain;
  background-repeat: no-repeat;
}
/* ===== 区切り線 ===== */
#fam-case-study-{{ section.id }} .fcs-divider {
  border: none;
  border-top: 1px solid var(--fcs-border);
  margin: 80px 0;
}
/* ===== ブログ一覧に戻るリンク ===== */
#fam-case-study-{{ section.id }} .fcs-back-link-wrap {
  margin-bottom: 40px;
}
#fam-case-study-{{ section.id }} .fcs-back-link-wrap--bottom {
  margin-bottom: 0;
  margin-top: 56px;
  padding-top: 40px;
  border-top: 1px solid var(--fcs-border);
}
#fam-case-study-{{ section.id }} .fcs-back-link {
  display: inline-flex !important;
  align-items: center;
  gap: 8px;
  font-family: var(--fcs-font-en);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--fcs-gray) !important;
  text-decoration: none !important;
  border-bottom: none !important;
  padding: 0 !important;
  transition: color 0.2s;
}
#fam-case-study-{{ section.id }} .fcs-back-link:hover {
  color: var(--fcs-orange) !important;
}
#fam-case-study-{{ section.id }} .fcs-back-link svg {
  flex-shrink: 0;
  transition: transform 0.2s;
}
#fam-case-study-{{ section.id }} .fcs-back-link:hover svg {
  transform: translateX(-3px);
}
/* ===== CTA ===== */
#fam-case-study-{{ section.id }} .fcs-cta {
  background: var(--fcs-dark);
  color: #fff;
  padding: 40px 48px;
  border-radius: 4px;
  margin-top: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
}
#fam-case-study-{{ section.id }} .fcs-cta__label {
  font-family: var(--fcs-font-en);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.2em;
  color: var(--fcs-orange);
  text-transform: uppercase;
  display: block;
  margin-bottom: 6px;
}
#fam-case-study-{{ section.id }} .fcs-cta__text {
  font-size: 16px;
  font-weight: 600;
  line-height: 1.5;
  color: #fff;
}
#fam-case-study-{{ section.id }} .fcs-cta__links {
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex-shrink: 0;
}
#fam-case-study-{{ section.id }} .fcs-cta-link {
  display: inline-flex !important;
  align-items: center;
  gap: 10px;
  font-family: var(--fcs-font-en);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--fcs-dark) !important;
  background: #fff !important;
  text-decoration: none !important;
  border: none !important;
  border-radius: 2px;
  padding: 12px 20px !important;
  white-space: nowrap;
  transition: background 0.2s, color 0.2s;
  line-height: 1;
}
#fam-case-study-{{ section.id }} .fcs-cta-link:hover {
  background: var(--fcs-orange) !important;
  color: #fff !important;
}
#fam-case-study-{{ section.id }} .fcs-cta-link svg {
  flex-shrink: 0;
  transition: transform 0.2s;
}
#fam-case-study-{{ section.id }} .fcs-cta-link:hover svg {
  transform: translateX(3px);
}
/* ===== SP ===== */
@media (max-width: 767px) {
  #fam-case-study-{{ section.id }} .fcs-wrap {
    padding: 48px 20px 72px;
  }
  #fam-case-study-{{ section.id }} .fcs-thumbnail { margin-bottom: 36px; }
  #fam-case-study-{{ section.id }} .fcs-cols {
    grid-template-columns: 1fr;
    gap: 24px;
  }
  #fam-case-study-{{ section.id }} .fcs-cols .fcs-col-img,
  #fam-case-study-{{ section.id }} .fcs-cols.img-left .fcs-col-img  { order: 1; }
  #fam-case-study-{{ section.id }} .fcs-cols .fcs-col-text,
  #fam-case-study-{{ section.id }} .fcs-cols.img-left .fcs-col-text { order: 2; }
  #fam-case-study-{{ section.id }} .fcs-stat-row { gap: 10px; }
  #fam-case-study-{{ section.id }} .fcs-stat__num { font-size: 26px; }
  #fam-case-study-{{ section.id }} .fcs-lead { font-size: 14px; }
  #fam-case-study-{{ section.id }} .fcs-divider { margin: 48px 0; }
  #fam-case-study-{{ section.id }} .fcs-cta {
    padding: 28px 24px;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }
  #fam-case-study-{{ section.id }} .fcs-cta__links {
    width: 100%;
    gap: 10px;
  }
  #fam-case-study-{{ section.id }} .fcs-cta-link {
    width: fit-content !important;
    min-width: 0 !important;
    justify-content: flex-start !important;
    white-space: normal !important;
    padding: 13px 18px !important;
    font-size: 10px;
    letter-spacing: 0.12em;
    gap: 12px;
    line-height: 1.3;
  }
  #fam-case-study-{{ section.id }} .fcs-cta-link svg {
    flex-shrink: 0;
  }
  #fam-case-study-{{ section.id }} .fcs-quote { padding: 20px; }
  #fam-case-study-{{ section.id }} .fcs-quote::before { display: none; }
  #fam-case-study-{{ section.id }} .fcs-article-date::before { display: none; }
  #fam-case-study-{{ section.id }} .fcs-article-meta { gap: 8px; }
}
</style>

<section id="fam-case-study-{{ section.id }}">
  <div class="fcs-wrap">

    {%- if section.settings.back_url != blank or section.settings.show_back_link -%}
    <div class="fcs-back-link-wrap">
      <a href="{{ section.settings.back_url | default: '/blogs/top' }}" class="fcs-back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13 8H3M3 8L7 4M3 8L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ section.settings.back_label | default: 'ブログ一覧に戻る' }}
      </a>
    </div>
    {%- endif -%}

    {%- for block in section.blocks -%}

      {%- if block.type == 'thumbnail' -%}
        {%- if block.settings.image != blank -%}
        <div class="fcs-thumbnail" {{ block.shopify_attributes }}>
          <div class="fcs-thumbnail__img-wrap">
            <img src="{{ block.settings.image | image_url: width: 1440 }}" alt="{{ block.settings.image.alt | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="eager">
          </div>
          {%- if block.settings.caption != blank -%}
          <p class="fcs-thumbnail__caption">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>
        {%- endif -%}

      {%- elsif block.type == 'article_header' -%}
        <div class="fcs-article-header" {{ block.shopify_attributes }}>
          {%- if block.settings.eyebrow != blank -%}
          <span class="fcs-eyebrow">{{ block.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
          <h2 class="fcs-article-title">{{ block.settings.title }}</h2>
          {%- endif -%}
          {%- if block.settings.subtitle != blank or block.settings.date != blank -%}
          <div class="fcs-article-meta">
            {%- if block.settings.subtitle != blank -%}
            <p class="fcs-article-subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
            {%- if block.settings.date != blank -%}
            <time class="fcs-article-date" datetime="{{ block.settings.date }}">{{ block.settings.date }}</time>
            {%- endif -%}
          </div>
          {%- endif -%}
          {%- if block.settings.lead != blank -%}
          <p class="fcs-lead">{{ block.settings.lead }}</p>
          {%- endif -%}
        </div>

      {%- elsif block.type == 'text_section' -%}
        {%- if block.settings.image != blank -%}
        <div class="fcs-cols{% if block.settings.image_position == 'left' %} img-left{% endif %}" {{ block.shopify_attributes }}>
          <div class="fcs-col-text">
            <div class="fcs-section">
              {%- if block.settings.heading != blank -%}
              <h3 class="fcs-section-heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
              <p class="fcs-section-body">{{ block.settings.body }}</p>
              {%- endif -%}
            </div>
          </div>
          <div class="fcs-col-img">
            <div class="fcs-img-wrap fcs-img-wrap--43">
              <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.image.alt | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
            </div>
            {%- if block.settings.image_caption != blank -%}
            <p class="fcs-img-caption">{{ block.settings.image_caption }}</p>
            {%- endif -%}
          </div>
        </div>
        {%- else -%}
        <div class="fcs-section" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
          <h3 class="fcs-section-heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
          <p class="fcs-section-body">{{ block.settings.body }}</p>
          {%- endif -%}
        </div>
        {%- endif -%}

      {%- elsif block.type == 'quote' -%}
        <blockquote class="fcs-quote" {{ block.shopify_attributes }}>
          <p class="fcs-quote__text">{{ block.settings.quote_text }}</p>
          {%- if block.settings.quote_name != blank -%}
          <span class="fcs-quote__name">{{ block.settings.quote_name }}</span>
          {%- endif -%}
        </blockquote>

      {%- elsif block.type == 'stats' -%}
        <div class="fcs-stat-row" {{ block.shopify_attributes }}>
          {%- if block.settings.stat1_num != blank -%}
          <div class="fcs-stat">
            <p class="fcs-stat__num">{{ block.settings.stat1_num }}</p>
            <p class="fcs-stat__label">{{ block.settings.stat1_label }}</p>
          </div>
          {%- endif -%}
          {%- if block.settings.stat2_num != blank -%}
          <div class="fcs-stat">
            <p class="fcs-stat__num">{{ block.settings.stat2_num }}</p>
            <p class="fcs-stat__label">{{ block.settings.stat2_label }}</p>
          </div>
          {%- endif -%}
        </div>

      {%- elsif block.type == 'image' -%}
        {%- if block.settings.image != blank -%}
        <div class="fcs-image-block" {{ block.shopify_attributes }}>
          {%- assign ratio_class = 'fcs-img-wrap--169' -%}
          {%- if block.settings.ratio == '4:3' -%}
            {%- assign ratio_class = 'fcs-img-wrap--43' -%}
          {%- elsif block.settings.ratio == 'free' -%}
            {%- assign ratio_class = 'fcs-img-wrap--free' -%}
          {%- endif -%}
          <div class="fcs-img-wrap {{ ratio_class }}">
            <img src="{{ block.settings.image | image_url: width: 1440 }}" alt="{{ block.settings.image.alt | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
          </div>
          {%- if block.settings.caption != blank -%}
          <p class="fcs-img-caption">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>
        {%- endif -%}

      {%- elsif block.type == 'checklist' -%}
        <div class="fcs-section" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
          <h3 class="fcs-section-heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          <ul class="fcs-checklist">
            {%- for i in (1..6) -%}
              {%- assign key = 'item' | append: i -%}
              {%- if block.settings[key] != blank -%}
              <li>{{ block.settings[key] }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>

      {%- elsif block.type == 'highlight' -%}
        <div class="fcs-highlight" {{ block.shopify_attributes }}>
          <p class="fcs-highlight__text">{{ block.settings.text }}</p>
        </div>

      {%- elsif block.type == 'article_divider' -%}
        <hr class="fcs-divider" {{ block.shopify_attributes }}>

      {%- elsif block.type == 'cta' -%}
        <div class="fcs-cta" {{ block.shopify_attributes }}>
          <div>
            {%- if block.settings.label != blank -%}
            <span class="fcs-cta__label">{{ block.settings.label }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
            <p class="fcs-cta__text">{{ block.settings.heading }}</p>
            {%- endif -%}
          </div>
          <div class="fcs-cta__links">
            {%- if block.settings.link1_url != blank -%}
            <a href="{{ block.settings.link1_url }}" class="fcs-cta-link" target="_blank" rel="noopener">
              {{ block.settings.link1_label }}
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            {%- endif -%}
            {%- if block.settings.link2_url != blank -%}
            <a href="{{ block.settings.link2_url }}" class="fcs-cta-link" target="_blank" rel="noopener">
              {{ block.settings.link2_label }}
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            {%- endif -%}
          </div>
        </div>

      {%- endif -%}
    {%- endfor -%}

    {%- if section.settings.back_url != blank or section.settings.show_back_link -%}
    <div class="fcs-back-link-wrap fcs-back-link-wrap--bottom">
      <a href="{{ section.settings.back_url | default: '/blogs/top' }}" class="fcs-back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M13 8H3M3 8L7 4M3 8L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ section.settings.back_label | default: 'ブログ一覧に戻る' }}
      </a>
    </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
