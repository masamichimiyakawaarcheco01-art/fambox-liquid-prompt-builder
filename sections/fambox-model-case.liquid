<!-- ============================================
     FAMBOX Model Case Section
     sections/fambox-model-case.liquid
     ============================================ -->
{%- liquid
  assign sec_id = 'fambox-model-case-' | append: section.id
-%}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@500&display=swap');

  /* ============================================
     BASE
     ============================================ */
  #{{ sec_id }} {
    position: relative;
    z-index: 1; /* ヘッダー(z-index:3-4)より下に配置 */
    width: 100%;
    background: #fafafa;
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    -webkit-font-smoothing: antialiased;
  }
  #{{ sec_id }} *,
  #{{ sec_id }} *::before,
  #{{ sec_id }} *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ============================================
     INNER: max-width 1440, padding で余白
     ============================================ */
  #{{ sec_id }} .mc__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 120px 56px;
  }

  /* ============================================
     セクションタイトル
     ============================================ */
  #{{ sec_id }} .mc__section-title {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-weight: 500 !important;
    font-size: 40px !important;
    line-height: 180% !important;
    color: #1B1D1A !important;
    margin-bottom: 56px !important;
  }

  /* ============================================
     箱コンテナ（横並び）
     ============================================ */
  #{{ sec_id }} .mc__boxes {
    display: flex;
    gap: 56px;
  }

  /* ============================================
     箱（flex:1、可変幅）
     ============================================ */
  #{{ sec_id }} .mc__box {
    flex: 1;
    min-width: 0;
  }

  /* ============================================
     ヘッダー行（Case + 目的テキスト）
     ============================================ */
  #{{ sec_id }} .mc__header-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 32px;
  }
  #{{ sec_id }} .mc__case-label {
    font-family: 'Poppins', sans-serif !important;
    font-weight: 500 !important;
    font-size: 32px !important;
    color: #FB4C15 !important;
    line-height: 1 !important;
  }
  #{{ sec_id }} .mc__case-purpose {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-weight: 600 !important;
    font-size: 24px !important;
    color: #FB4C15 !important;
    line-height: 1 !important;
  }

  /* ============================================
     区切り線（2px #1B1D1A）
     div:empty対策: Liquidコメント挿入
     ============================================ */
  #{{ sec_id }} .mc__divider {
    height: 2px !important;
    background: #1B1D1A !important;
    width: 100% !important;
    display: block !important;
  }

  /* ============================================
     箱内タイトル
     ============================================ */
  #{{ sec_id }} .mc__box-title {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-weight: 600 !important;
    font-size: 24px !important;
    color: #1B1D1A !important;
    line-height: 170% !important;
    margin-top: 32px !important;
    margin-bottom: 16px !important;
  }

  /* ============================================
     箱内文章
     ============================================ */
  #{{ sec_id }} .mc__box-desc {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-weight: 400 !important;
    font-size: 14px !important;
    color: #545655 !important;
    line-height: 180% !important;
    margin-bottom: 32px !important;
  }

  /* ============================================
     データ行（72px高、#ECECEC下線）
     ============================================ */
  #{{ sec_id }} .mc__data-row {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    height: 72px !important;
    border-bottom: 2px solid #ECECEC !important;
  }
  #{{ sec_id }} .mc__data-label {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-weight: 500 !important;
    font-size: 16px !important;
    color: #1B1D1A !important;
    line-height: 1 !important;
  }
  #{{ sec_id }} .mc__data-value {
    font-family: 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif !important;
    font-weight: 500 !important;
    font-size: 16px !important;
    color: #1B1D1A !important;
    line-height: 1 !important;
    text-align: right !important;
  }

  /* ============================================
     合計行（下線なし、24px）
     ============================================ */
  #{{ sec_id }} .mc__data-row--total {
    border-bottom: none !important;
  }
  #{{ sec_id }} .mc__data-row--total .mc__data-label,
  #{{ sec_id }} .mc__data-row--total .mc__data-value {
    font-size: 20px !important;
    font-weight: 500 !important;
  }

  /* ============================================
     SP版（900px以下）
     ============================================ */
  @media (max-width: 900px) {
    #{{ sec_id }} .mc__inner {
      padding: 80px 24px;
    }
    #{{ sec_id }} .mc__boxes {
      flex-direction: column;
      gap: 56px;
    }
    #{{ sec_id }} .mc__section-title {
      font-size: 28px !important;
    }
    #{{ sec_id }} .mc__case-label {
      font-size: 24px !important;
    }
    #{{ sec_id }} .mc__case-purpose {
      font-size: 20px !important;
    }
    #{{ sec_id }} .mc__box-title {
      font-size: 20px !important;
    }
    #{{ sec_id }} .mc__data-label,
    #{{ sec_id }} .mc__data-value {
      font-size: 14px !important;
    }
    #{{ sec_id }} .mc__data-row--total .mc__data-label,
    #{{ sec_id }} .mc__data-row--total .mc__data-value {
      font-size: 16px !important;
    }
  }
</style>

<section id="{{ sec_id }}">
  <div class="mc__inner">

    <!-- セクションタイトル -->
    <h2 class="mc__section-title">{{ section.settings.section_title }}</h2>

    <!-- 箱コンテナ -->
    <div class="mc__boxes">

      {%- for block in section.blocks -%}
        {%- if block.type == 'case_box' -%}
          <div class="mc__box" {{ block.shopify_attributes }}>

            <!-- ヘッダー: Case + 目的 -->
            <div class="mc__header-row">
              <span class="mc__case-label">{{ block.settings.case_label }}</span>
              <span class="mc__case-purpose">{{ block.settings.case_purpose }}</span>
            </div>

            <!-- 区切り線 -->
            <div class="mc__divider">{%- comment -%}not empty{%- endcomment -%}</div>

            <!-- タイトル -->
            <h3 class="mc__box-title">{{ block.settings.box_title | newline_to_br }}</h3>

            <!-- 文章 -->
            <p class="mc__box-desc">{{ block.settings.box_desc | newline_to_br }}</p>

            <!-- 区切り線 -->
            <div class="mc__divider">{%- comment -%}not empty{%- endcomment -%}</div>

            <!-- データ行1 -->
            <div class="mc__data-row">
              <span class="mc__data-label">{{ block.settings.row1_label }}</span>
              <span class="mc__data-value">{{ block.settings.row1_value }}</span>
            </div>

            <!-- データ行2 -->
            <div class="mc__data-row">
              <span class="mc__data-label">{{ block.settings.row2_label }}</span>
              <span class="mc__data-value">{{ block.settings.row2_value }}</span>
            </div>

            <!-- データ行3 -->
            <div class="mc__data-row">
              <span class="mc__data-label">{{ block.settings.row3_label }}</span>
              <span class="mc__data-value">{{ block.settings.row3_value }}</span>
            </div>

            <!-- データ行4 -->
            <div class="mc__data-row">
              <span class="mc__data-label">{{ block.settings.row4_label }}</span>
              <span class="mc__data-value">{{ block.settings.row4_value }}</span>
            </div>

            <!-- 合計行 -->
            <div class="mc__data-row mc__data-row--total">
              <span class="mc__data-label">{{ block.settings.total_label }}</span>
              <span class="mc__data-value">{{ block.settings.total_value }}</span>
            </div>

          </div>
        {%- endif -%}
      {%- endfor -%}

    </div><!-- /.mc__boxes -->

  </div><!-- /.mc__inner -->
</section>

{% schema %}
{
