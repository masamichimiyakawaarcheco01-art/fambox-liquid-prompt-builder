{% comment %}
  Section: FAM 商品タイトル（勝負メシ）
  File: sections/fam-solution.liquid
{% endcomment %}
<div class="fsol" id="fsol-{{ section.id }}">
<!-- 背景楕円 PC -->
{% if section.settings.subtract_pc != blank %}
<img class="fsol__subtract fsol__subtract--pc" src="{{ section.settings.subtract_pc | image_url: width: 1440 }}" alt="" width="1440" height="722" aria-hidden="true">
{% endif %}
<!-- 背景楕円 SP -->
{% if section.settings.subtract_sp != blank %}
<img class="fsol__subtract fsol__subtract--sp" src="{{ section.settings.subtract_sp | image_url: width: 390 }}" alt="" width="390" height="196" aria-hidden="true">
{% endif %}
<!-- 人物写真 PC -->
{% if section.settings.photo_pc != blank %}
<img class="fsol__photo fsol__photo--pc" src="{{ section.settings.photo_pc | image_url: width: 1200 }}" alt="" width="1044" height="522" loading="lazy">
{% endif %}
<!-- 人物写真 SP -->
{% if section.settings.photo_sp != blank %}
<img class="fsol__photo fsol__photo--sp" src="{{ section.settings.photo_sp | image_url: width: 600 }}" alt="" width="500" height="250" loading="lazy">
{% endif %}
<!-- タイトル PC -->
{% if section.settings.title_image_pc != blank %}
<img class="fsol__title fsol__title--pc" src="{{ section.settings.title_image_pc | image_url: width: 480 }}" alt="{{ section.settings.title_alt }}" width="240" height="364" loading="eager">
{% endif %}
<!-- タイトル SP -->
{% if section.settings.title_image_sp != blank %}
<img class="fsol__title fsol__title--sp" src="{{ section.settings.title_image_sp | image_url: width: 360 }}" alt="{{ section.settings.title_alt }}" width="180" height="273" loading="eager">
{% endif %}
<!-- ボタン PC -->
<div class="fsol__cta fsol__cta--pc">
<a href="{{ section.settings.button_url }}" class="fsol__btn">
<span class="fsol__btn-text">{{ section.settings.button_label }}</span>
<span class="fsol__btn-arrow">
{%- if section.settings.cta_arrow_svg != blank -%}
{{ section.settings.cta_arrow_svg }}
{%- elsif section.settings.cta_arrow_icon != blank -%}
<img src="{{ section.settings.cta_arrow_icon | image_url: width: 80 }}" alt="" width="40" height="14">
{%- else -%}
<svg width="40" height="14" viewBox="0 0 53 12" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="5" width="46" height="2" fill="white"/><path d="M46 0L53 6L46 12V0Z" fill="white"/></svg>
{%- endif -%}
</span>
</a>
</div>
<!-- ボタン SP -->
<div class="fsol__cta fsol__cta--sp">
<a href="{{ section.settings.button_url }}" class="fsol__btn">
<span class="fsol__btn-text">{{ section.settings.button_label }}</span>
<span class="fsol__btn-arrow">
{%- if section.settings.cta_arrow_svg != blank -%}
{{ section.settings.cta_arrow_svg }}
{%- elsif section.settings.cta_arrow_icon != blank -%}
<img src="{{ section.settings.cta_arrow_icon | image_url: width: 80 }}" alt="" width="40" height="14">
{%- else -%}
<svg width="40" height="14" viewBox="0 0 53 12" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="5" width="46" height="2" fill="white"/><path d="M46 0L53 6L46 12V0Z" fill="white"/></svg>
{%- endif -%}
</span>
</a>
</div>
</div>
<style>
/* ===== Shopify親要素のoverflow解除 ===== */
.shopify-section:has(#fsol-{{ section.id }}) {
overflow: visible !important;
padding: 0 !important;
margin: 0 !important;
}
/* ===== ルート ===== */
.fsol {
position: relative;
z-index: 1; /* ヘッダー(z-index:3-4)より下に配置 */
width: 100%;
height: 722px;
background: #fafafa;
overflow: hidden;
font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", sans-serif;
box-shadow: inset 0 -74px 0 0 #FB4C15;
}
/* ===== 背景楕円 z-index:1 ===== */
.fsol__subtract {
position: absolute;
top: 0;
display: block;
height: auto;
z-index: 1;
pointer-events: none;
}
.fsol__subtract--pc {
width: 1440px;
left: 50%;
transform: translateX(-50%);
}
.fsol__subtract--sp { display: none; }
/* ===== 人物写真 z-index:2 ===== */
.fsol__photo {
position: absolute;
left: 50%;
transform: translateX(-50%);
z-index: 2;
pointer-events: none;
display: block;
height: auto;
isolation: isolate;
}
.fsol__photo--pc {
top: 200px;
width: 1044px;
}
.fsol__photo--sp { display: none; }
/* ===== タイトル画像 z-index:3 ===== */
.fsol__title {
position: absolute;
left: 50%;
transform: translateX(-50%);
display: block;
height: auto;
z-index: 3;
}
.fsol__title--pc {
top: 96px;
width: 240px;
}
.fsol__title--sp { display: none; }
/* ===== CTAボタン z-index:4 ===== */
.fsol__cta {
position: absolute;
z-index: 4;
width: 320px;
height: 48px;
}
.fsol__cta--pc {
display: block;
top: 500px;
left: 50%;
transform: translateX(-50%);
}
.fsol__cta--sp { display: none; }
/* ボタン本体 */
.fsol__btn {
display: inline-flex;
align-items: center;
justify-content: center;
width: 320px;
height: 48px;
border-radius: 4px;
background: linear-gradient(to bottom, rgba(251,76,21,0.90), rgba(251,76,21,0.95));
border: 1px solid rgba(255,255,255,0.1);
font-family: "Hiragino Sans", "Hiragino Kaku Gothic ProN", sans-serif;
font-size: 14px;
font-weight: 700;
color: #ffffff !important;
text-decoration: none !important;
letter-spacing: 0.08em;
box-sizing: border-box;
box-shadow: 0 16px 16px -8px rgba(251,76,21,0.35);
transition: filter 0.3s ease;
position: relative;
}
.fsol__btn:hover { filter: brightness(1.12); }
.fsol__btn:active { filter: brightness(0.95); }
.fsol__btn-text {
position: relative;
z-index: 1;
color: #ffffff;
}
.fsol__btn-arrow {
position: absolute;
right: 16px;
top: 50%;
transform: translateY(-50%);
display: inline-flex;
align-items: center;
line-height: 0;
transition: transform 0.3s ease;
}
.fsol__btn-arrow img,
.fsol__btn-arrow svg { display: block; width: 36px; height: 14px; }
.fsol__btn:hover .fsol__btn-arrow,
.fsol__btn:active .fsol__btn-arrow { transform: translateY(-50%) translateX(4px); }
/* ===== PC（768px以上） ===== */
@media (min-width: 768px) {
.fsol__subtract--pc { display: block; }
.fsol__subtract--sp { display: none; }
.fsol__photo--pc { display: block; }
.fsol__photo--sp { display: none; }
.fsol__title--pc { display: block; }
.fsol__title--sp { display: none; }
.fsol__cta--pc { display: block; }
.fsol__cta--sp { display: none; }
}
/* ===== SP（767px以下） ===== */
@media (max-width: 767px) {
.fsol {
height: 548px;
box-shadow: inset 0 -34px 0 0 #FB4C15;
  }
.fsol__subtract--pc { display: none; }
.fsol__subtract--sp {
display: block;
width: 100%;
left: 0;
transform: none;
  }
.fsol__photo--pc { display: none; }
.fsol__photo--sp {
display: block;
top: 298px;
width: 500px;
  }
.fsol__title--pc { display: none; }
.fsol__title--sp {
display: block;
top: 80px;
width: 180px;
  }
.fsol__cta--pc { display: none; }
.fsol__cta--sp {
display: block;
top: 405px;
left: 50%;
transform: translateX(-50%);
  }
}
</style>
{% schema %}
{
"name": "FAM 勝負メシ",
"settings": [
    {
"type": "html",
"id": "cta_arrow_svg",
"label": "CTAボタン 矢印SVGコード（最優先）",
"info": "FigmaからSVGをコピーして貼り付け。空欄の場合は下の画像またはデフォルトSVGを使用"
    },
    {
"type": "image_picker",
"id": "cta_arrow_icon",
"label": "CTAボタン 矢印アイコン（SVG未設定時に使用）"
    },
    {
"type": "image_picker",
"id": "subtract_pc",
"label": "背景楕円シェイプ（PC用）",
"info": "白い楕円の装飾画像。1440×722px推奨"
    },
    {
"type": "image_picker",
"id": "subtract_sp",
"label": "背景楕円シェイプ（SP用）",
"info": "白い楕円の装飾画像。390×196px推奨"
    },
    {
"type": "image_picker",
"id": "title_image_pc",
"label": "タイトル画像（PC用）",
"info": "「管理栄養士監修 和田毅の勝負メシ」テキスト画像。240×364px推奨"
    },
    {
"type": "image_picker",
"id": "title_image_sp",
"label": "タイトル画像（SP用）",
"info": "「管理栄養士監修 和田毅の勝負メシ」テキスト画像。180×273px推奨"
    },
    {
"type": "text",
"id": "title_alt",
"label": "タイトル画像のalt文",
"default": "管理栄養士監修 和田毅の勝負メシ"
    },
    {
"type": "image_picker",
"id": "photo_pc",
"label": "人物写真（PC用）",
"info": "栄養士・アスリート・料理の写真。1044×522px推奨"
    },
    {
"type": "image_picker",
"id": "photo_sp",
"label": "人物写真（SP用）",
"info": "500×250px推奨"
    },
    {
"type": "text",
"id": "button_label",
"label": "ボタンテキスト",
"default": "メニューを見る"
    },
    {
"type": "url",
"id": "button_url",
"label": "ボタンリンク先"
    }
  ],
"presets": [
    {
"name": "FAM 勝負メシ"
    }
  ]
}
{% endschema %}
